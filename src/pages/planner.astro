  </div>

  <script is:inline data-astro-rerun>
  (function() {
    var introCard = document.getElementById('jp-intro');
    var navBar = document.getElementById('jp-nav');
    var panels = document.querySelectorAll('.jp-step-panel');
    var tabs = document.querySelectorAll('.jp-step-tab');
    var current = -1;

    function showPanel(idx) {
      introCard.style.display = 'none';
      navBar.style.display = 'flex';
      panels.forEach(function(p){ p.classList.remove('is-active'); });
      tabs.forEach(function(t){ t.classList.remove('is-active'); });
      var panel = document.querySelector('[data-panel="' + idx + '"]');
      if (panel) panel.classList.add('is-active');
      if (idx < 5) tabs[idx].classList.add('is-active');
      current = idx;
      window.scrollTo({ top: navBar.offsetTop - 100, behavior: 'smooth' });
    }

    document.getElementById('jp-start').addEventListener('click', function() {
      showPanel(0);
    });

    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() { showPanel(parseInt(tab.getAttribute('data-step'))); });
    });

    document.querySelectorAll('.jp-btn-next, .jp-btn-back').forEach(function(btn) {
      btn.addEventListener('click', function() { showPanel(parseInt(btn.getAttribute('data-to'))); });
    });

    // Checklist counters
    function setupCounter(listId, counterId) {
      var list = document.getElementById(listId);
      var counter = document.getElementById(counterId);
      if (!list || !counter) return;
      var boxes = list.querySelectorAll('input[type="checkbox"]');
      var total = boxes.length;
      function update() {
        var checked = list.querySelectorAll('input[type="checkbox"]:checked').length;
        counter.textContent = checked + ' of ' + total;
        counter.classList.toggle('is-complete', checked === total);
      }
      boxes.forEach(function(cb) { cb.addEventListener('change', update); });
      update();
    }
    setupCounter('jp-setting-list', 'jp-setting-counter');
    setupCounter('jp-safety-list', 'jp-safety-counter');
    setupCounter('jp-integration-list', 'jp-integration-counter');

    /* ======================================================
       SUBSTANCE DATA
       ====================================================== */
    var SUBSTANCE_DATA = {
      'Psilocybin mushrooms': {
        duration: '4–6 hours',
        onset: '20–60 minutes',
        points: [
          'Nausea is common on the come-up, especially on a full stomach. Ginger tea can help.',
          'Lemon tek (ground mushrooms soaked in lemon juice for 20 min) accelerates onset and may intensify the peak.',
          'Empty stomach recommended — eat lightly 3–4 hours before.',
          'Effects build gradually. Do not redose within the first 90 minutes.'
        ],
        guide: '/psilocybin',
        guideName: 'Psilocybin Guide',
        criticalSafety: [],
        dietNote: null
      },
      'LSD': {
        duration: '8–12 hours',
        onset: '30–90 minutes',
        points: [
          'Very long duration — ensure your entire day and evening are free of obligations.',
          'Do not redose. Tolerance builds immediately; a second dose extends duration without proportionally increasing intensity.',
          'Test your tabs with a reagent kit (Ehrlich/Hofmann). NBOMe compounds sold as LSD can be dangerous.',
          'Effects may continue to shift and evolve for the full 12 hours. This is normal.'
        ],
        guide: '/lsd',
        guideName: 'LSD Guide',
        criticalSafety: ['Substance has been verified'],
        dietNote: null
      },
      'DMT (smoked/vaporised)': {
        duration: '5–20 minutes',
        onset: 'Seconds',
        points: [
          'Extremely intense. Often described as the most powerful psychedelic experience possible.',
          'A sitter is essential — you will be unable to move or communicate during the peak.',
          'Have a safe place to lie down immediately before inhaling.',
          'The short duration does not reduce the psychological intensity. Integration is still important.'
        ],
        guide: '/dmt',
        guideName: 'DMT Guide',
        criticalSafety: ['Sitter knows the substance, dose, and expected duration', 'Sitter knows what to do if things become difficult'],
        dietNote: null
      },
      'Ayahuasca': {
        duration: '4–6 hours',
        onset: '20–60 minutes',
        points: [
          'Dietary restrictions are critical: avoid tyramine-containing foods (aged cheese, cured meats, fermented foods, soy sauce) for at least 24–48 hours before.',
          'MAOI interactions are life-threatening. SSRIs, SNRIs, stimulants, and many other medications must be discontinued well in advance. Use the Interaction Checker.',
          'Purging (vomiting, diarrhoea) is common and considered part of the process. It is not a sign something is wrong.',
          'Should be taken in a supported setting with experienced facilitation, not solo.'
        ],
        guide: '/ayahuasca',
        guideName: 'Ayahuasca Guide',
        criticalSafety: ['No dangerous medication interactions', 'Fasted or eaten lightly'],
        dietNote: 'Ayahuasca requires strict dietary preparation (tyramine-free diet) for at least 24–48 hours before the ceremony. This is a safety requirement, not optional.'
