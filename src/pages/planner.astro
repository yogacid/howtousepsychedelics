          <p class="jp-pdf-desc">Enter your email to receive your preparation plan as a formatted PDF you can save, print, and refer back to.</p>
          <form id="jpPdfForm" class="jp-pdf-form" autocomplete="on">
            <input type="text" name="first_name" placeholder="First name (optional)" class="jp-pdf-input" autocomplete="given-name" />
            <input type="email" name="email" placeholder="Your email" class="jp-pdf-input" required autocomplete="email" />
            <input type="text" name="_hp" class="jp-pdf-hp" tabindex="-1" autocomplete="off" />
            <button type="submit" class="jp-pdf-btn" id="jpPdfBtn"><span id="jpPdfBtnText">Download Plan as PDF &rarr;</span></button>
