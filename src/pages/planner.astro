      'Mescaline (cactus)': {
        duration: '8–12 hours',
        onset: '45–120 minutes',
        points: [
          'Very long experience — plan for a full day with no obligations.',
          'Nausea is common and sometimes intense, particularly during the first 1–2 hours.',
          'Slow onset can tempt redosing — wait at least 2 hours before concluding the dose was insufficient.',
          'The body load is significant. Stay hydrated and have a comfortable place to rest.'
        ],
        guide: '/mescaline',
        guideName: 'Mescaline Guide',
        criticalSafety: [],
        dietNote: null
      },
      '5-MeO-DMT': {
        duration: '15–45 minutes',
        onset: 'Seconds',
        points: [
          'One of the most powerful psychedelics known. Non-negotiable: an experienced sitter must be present.',
          'Complete ego dissolution is common. You may thrash, vocalise, or stop breathing briefly.',
          'Multiple fatalities have occurred when combined with MAOIs. Never combine with any other substance.',
          'Not recreational. Requires significant psychological preparation and integration support.'
        ],
        guide: '/fivemedmt',
        guideName: '5-MeO-DMT Guide',
        criticalSafety: ['Sitter knows the substance, dose, and expected duration', 'Sitter knows what to do if things become difficult', 'Not combining with other substances'],
        dietNote: null
      },
      'MDMA': {
        duration: '3–5 hours',
        onset: '30–60 minutes',
        points: [
          'Stay hydrated but do not overhydrate — sip water regularly (250ml/hour), do not gulp large amounts.',
          'Monitor body temperature. Overheating is a serious risk, especially in warm environments.',
          'Neurotoxicity increases at high doses and with frequent use. Never exceed 1.5mg/kg bodyweight.',
          'The 3-month rule: allow minimum 3 months between uses to reduce neurotoxic risk and tolerance.'
        ],
        guide: '/mdma',
        guideName: 'MDMA Guide',
        criticalSafety: ['No dangerous medication interactions', 'Not combining with other substances'],
        dietNote: null
      },
      'Ketamine': {
        duration: '45–90 minutes',
        onset: 'Minutes',
        points: [
          'Dissociative anaesthetic, not a classical psychedelic. The experience is qualitatively different.',
          'Do not combine with alcohol, opioids, or benzodiazepines — respiratory depression risk is real.',
          'Low doses are psychedelic/therapeutic; high doses produce full dissociation (K-hole). Know which you are aiming for.',
          'Bladder damage occurs with frequent use. Occasional use at moderate doses carries lower risk.'
        ],
        guide: '/ketamine',
        guideName: 'Ketamine Guide',
        criticalSafety: ['Not combining with other substances'],
        dietNote: null
      },
      '2C-B': {
        duration: '4–6 hours',
        onset: '45–75 minutes (oral)',
        points: [
          'Strongly dose-sensitive: a 5mg difference can dramatically change the experience. Weigh carefully.',
          'Has stimulant and empathogenic properties alongside psychedelic effects.',
          'Nasal administration is extremely painful and hits much harder. Oral recommended.',
          'Body load can be significant at higher doses. Start with 15–20mg oral for a first experience.'
        ],
        guide: '/twocb',
        guideName: '2C-B Guide',
        criticalSafety: ['Dose has been carefully measured'],
        dietNote: null
      }
    };

    /* ======================================================
       SAFETY ITEM EXPLANATIONS
       ====================================================== */
    var SAFETY_EXPLANATIONS = [
      { text: 'No medical contraindications', explanation: 'Unscreened medical conditions (heart problems, seizure disorders, psychotic conditions) can cause dangerous reactions. If you have not assessed this, complete the Readiness Assessment first.', link: '/readiness/', linkText: 'Readiness Assessment' },
      { text: 'No dangerous medication interactions', explanation: 'Some combinations are life-threatening — SSRIs with MDMA or ayahuasca, lithium with any psychedelic, MAOIs with many substances. This is not optional.', link: '/checker/', linkText: 'Interaction Checker' },
      { text: 'Substance has been verified', explanation: 'Unverified substances may contain dangerous adulterants, wrong compounds, or wildly inaccurate doses. Reagent testing takes minutes and can save your life.' },
      { text: 'Dose has been carefully measured', explanation: 'Estimating doses leads to unexpectedly intense experiences. Use a milligram scale for powders, count tabs/caps carefully, and know the expected potency of your source.' },
      { text: 'Sitter knows the substance, dose, and expected duration', explanation: 'Your sitter needs this information to provide appropriate support and to know when something is within normal range versus a genuine concern.' },
      { text: 'Sitter knows what to do if things become difficult', explanation: 'Difficult experiences require calm, grounding presence — not panic. Brief your sitter on: staying calm, offering reassurance, not trying to talk you out of the experience, and when to seek help.' },
      { text: 'Emergency contact identified', explanation: 'If you are alone or if your sitter needs help, someone outside the situation should know how to be reached. Leave a note or send a text in advance.' },
      { text: 'Benzodiazepine or similar available', explanation: 'A benzodiazepine (e.g. diazepam) can significantly reduce a difficult psychedelic experience within 20–30 minutes. Having one available reduces anxiety even if you never use it.' },
      { text: 'Not combining with other substances', explanation: 'Combinations multiply unpredictability and risk. Cannabis can dramatically intensify psychedelics; alcohol impairs judgement; stimulants add cardiovascular strain.' },
      { text: 'Fasted or eaten lightly', explanation: 'A full stomach increases nausea (especially with mushrooms, ayahuasca, and mescaline) and can reduce or delay absorption. Eat lightly 3–4 hours before.' }
    ];

    /* ======================================================
       INTEGRATION ITEM EXPLANATIONS
       ====================================================== */
    var INTEGRATION_EXPLANATIONS = [
      { text: 'Journal and pen ready', explanation: 'Insights and felt-sense impressions fade quickly after a psychedelic experience. Even brief notes captured within the first hours can be invaluable weeks later.' },
      { text: 'No high-stakes obligations for 1–3 days', explanation: 'Integration requires psychological space. Major decisions, difficult conversations, and high-pressure work should wait until you have processed the experience.' },
      { text: 'Trusted person available to talk to', explanation: 'Verbalising the experience with a trusted listener helps consolidate meaning. You do not need to explain everything — just speaking aloud helps.' },
      { text: 'Therapist or integration coach identified', explanation: 'If difficult material surfaces, professional support can be essential. Having someone identified in advance means you do not need to search while vulnerable.' },
      { text: 'Time in nature planned', explanation: 'Nature contact supports the integration of expanded awareness. Even a walk in a park within 24–48 hours can help ground insights.' },
      { text: 'Reviewed the Integration Guide', explanation: 'Structured integration practices (journaling prompts, meditation, somatic exercises) prevent insights from dissolving back into daily autopilot.', link: '/integration/', linkText: 'Integration Guide' },
      { text: 'Clear of alcohol and cannabis for 1+ week', explanation: 'Alcohol and cannabis can blur the integration window. They may reintroduce avoidance patterns or override the subtle shifts the experience produced.' },
      { text: 'Gentler exercise, meditation, or breathwork', explanation: 'Embodied practices (yoga, walking, breathwork) help ground psychedelic insights in the body rather than keeping them purely conceptual.' }
    ];

    /* ======================================================
       SUBSTANCE-SPECIFIC GUIDANCE (Step 1)
       ====================================================== */
    var subSelect = document.getElementById('pl-sub');
    var subNote = document.getElementById('jp-sub-note');
    subSelect.addEventListener('change', function() {
      var data = SUBSTANCE_DATA[subSelect.value];
      if (data) {
        var html = '<div class="jp-sub-card">';
        html += '<div class="jp-sub-card-header">';
        html += '<span>Duration: <span class="jp-sub-val">' + data.duration + '</span></span>';
        html += '<span>Onset: <span class="jp-sub-val">' + data.onset + '</span></span>';
        html += '</div>';
        html += '<ul class="jp-sub-card-points">';
        data.points.forEach(function(p) { html += '<li>' + p + '</li>'; });
        html += '</ul>';
        html += '<a class="jp-sub-card-link" href="' + data.guide + '/">Read the full ' + data.guideName + ' →</a>';
        html += '</div>';
        subNote.innerHTML = html;
        subNote.style.display = 'block';
      } else {
        subNote.style.display = 'none';
      }
      checkCombos();
    });

    /* ======================================================
       COMBO WARNINGS (Step 1)
       ====================================================== */
    var doseSelect = document.getElementById('pl-dose');
    var expSelect = document.getElementById('pl-exp');
    var comboWarn = document.getElementById('jp-combo-warn');

    function checkCombos() {
      var sub = subSelect.value;
      var dose = doseSelect.value;
      var exp = expSelect.value;
      var warns = [];

      if (exp === 'First time ever' && (dose === 'High dose (strong)' || dose === 'Heroic dose (very high)')) {
        warns.push('A high or heroic dose for a first psychedelic experience carries significantly elevated risk of psychological crisis. Start with a low or moderate dose to understand how you respond.');
      }
      if (dose === 'Heroic dose (very high)' && exp === 'First time with this substance') {
        warns.push('A heroic dose with a substance you have not used before is high-risk. Each substance has a different character — start lower to learn how you respond to this one.');
      }
      if ((sub === '5-MeO-DMT' || sub === 'DMT (smoked/vaporised)') && (dose === 'High dose (strong)' || dose === 'Heroic dose (very high)' || dose === 'Moderate dose (standard)')) {
        warns.push(sub + ' is extremely intense even at moderate doses. Ensure an experienced sitter is present (Step 3).');
      }
      if (sub === 'Ayahuasca' && exp === 'First time ever') {
        warns.push('Ayahuasca is not recommended as a first psychedelic experience without experienced ceremonial facilitation. Ensure appropriate support is in place (Step 3).');
      }

      if (warns.length > 0) {
        var html = '<div class="jp-combo-warn-title">⚠ Safety Concern' + (warns.length > 1 ? 's' : '') + '</div>';
        warns.forEach(function(w) { html += '<div class="jp-combo-warn-item">' + w + '</div>'; });
        comboWarn.innerHTML = html;
        comboWarn.style.display = 'block';
      } else {
        comboWarn.style.display = 'none';
      }
    }

    doseSelect.addEventListener('change', checkCombos);
    expSelect.addEventListener('change', checkCombos);

    /* ======================================================
       DATE PREPARATION NOTE
       ====================================================== */
    var dateInput = document.getElementById('pl-date');
    var dateNote = document.getElementById('jp-date-note');
    dateInput.addEventListener('change', function() {
      if (!dateInput.value) { dateNote.style.display = 'none'; return; }
      var chosen = new Date(dateInput.value);
      var today = new Date();
      today.setHours(0,0,0,0);
      var diffMs = chosen - today;
      var diffDays = Math.ceil(diffMs / (1000 * 60 * 60 * 24));
      if (diffDays < 0) {
        dateNote.textContent = 'This date is in the past.';
        dateNote.className = 'jp-date-note jp-date-warn';
      } else if (diffDays === 0) {
        dateNote.textContent = "That\u2019s today. If you haven\u2019t already completed your preparation, consider postponing.";
        dateNote.className = 'jp-date-note jp-date-warn';
      } else if (diffDays <= 2) {
        dateNote.textContent = diffDays + ' day' + (diffDays === 1 ? '' : 's') + ' away. This is a short preparation window. Ensure all safety and setting items are already in place.';
        dateNote.className = 'jp-date-note jp-date-warn';
      } else if (diffDays <= 7) {
        dateNote.textContent = diffDays + ' days away. A reasonable preparation window. Use this time to finalise your setting, refine your intention, and complete your safety checklist.';
        dateNote.className = 'jp-date-note jp-date-ok';
      } else if (diffDays <= 30) {
        dateNote.textContent = diffDays + ' days away. A good amount of preparation time. Consider journaling, meditation, and reading about your chosen substance in the weeks ahead.';
        dateNote.className = 'jp-date-note jp-date-good';
      } else {
        dateNote.textContent = diffDays + ' days away. Plenty of time to prepare thoroughly. Use the weeks ahead for intentional preparation — reading, journaling, meditation, and lifestyle adjustments.';
        dateNote.className = 'jp-date-note jp-date-good';
      }
      dateNote.style.display = 'block';
    });

    /* ======================================================
       SMART PLAN SUMMARY GENERATION
       ====================================================== */
    function val(id) { var el = document.getElementById(id); return el ? (el.value || '') : ''; }
    function countChecked(id) {
      var el = document.getElementById(id);
      if (!el) return { c: 0, t: 0 };
      return { c: el.querySelectorAll('input:checked').length, t: el.querySelectorAll('input[type="checkbox"]').length };
    }
    function getChecklistStates(listId) {
      var el = document.getElementById(listId);
      if (!el) return [];
      var items = [];
      el.querySelectorAll('.jp-check-item').forEach(function(item) {
        var cb = item.querySelector('input[type="checkbox"]');
        var spans = item.querySelectorAll('span');
        var text = spans[spans.length - 1].textContent.trim();
        items.push({ checked: cb.checked, text: text });
      });
      return items;
    }

    document.getElementById('jp-generate').addEventListener('click', function() {
      var sub = val('pl-sub'), dose = val('pl-dose'), exp = val('pl-exp'), source = val('pl-source');
      var intention = val('pl-intent-text'), explore = val('pl-explore'), fears = val('pl-fears'), outcome = val('pl-outcome'), release = val('pl-release');
      var location = val('pl-location'), sitter = val('pl-sitter'), date = val('pl-date');
      var sc = countChecked('jp-setting-list'), saf = countChecked('jp-safety-list'), intg = countChecked('jp-integration-list');
      var totalC = sc.c + saf.c + intg.c, totalT = sc.t + saf.t + intg.t;
      var pct = totalT > 0 ? Math.round((totalC / totalT) * 100) : 0;

      var safetyStates = getChecklistStates('jp-safety-list');
      var integrationStates = getChecklistStates('jp-integration-list');

      // ── Build Warnings ──
      var warnings = [];
      if (source === 'Unverified') warnings.push('Your substance is unverified. Reagent testing is strongly recommended before any use.');
      if (exp === 'First time ever' && (dose === 'High dose (strong)' || dose === 'Heroic dose (very high)')) warnings.push('A high or heroic dose for a first experience carries significantly elevated risk of psychological crisis. Consider starting with a low or moderate dose.');
      if (sitter === 'No — solo' && exp === 'First time ever') warnings.push('Solo use for a first psychedelic experience is strongly discouraged. A trusted sitter significantly reduces risk.');
      if ((dose === 'High dose (strong)' || dose === 'Heroic dose (very high)') && sitter === 'No — solo') warnings.push('High-dose experiences without a sitter present substantial safety risk.');
      if (sub === '5-MeO-DMT' && sitter === 'No — solo') warnings.push('5-MeO-DMT should never be taken without an experienced sitter. This is non-negotiable.');
      if (sub === 'Ayahuasca' && sitter === 'No — solo') warnings.push('Ayahuasca should be taken in a supported setting with experienced facilitation.');
      if (!intention && !explore) warnings.push('No intention has been written. Consider returning to Step 2 to clarify your intention before proceeding.');
      if (dose === 'Unsure') warnings.push('You are unsure about your dose. Research your chosen substance thoroughly and start conservatively.');

      // ── Substance cross-references ──
      var subData = SUBSTANCE_DATA[sub];
      var crossRefs = [];
      if (subData && subData.criticalSafety.length > 0) {
        subData.criticalSafety.forEach(function(critText) {
          for (var si = 0; si < safetyStates.length; si++) {
            if (safetyStates[si].text.indexOf(critText) !== -1 && !safetyStates[si].checked) {
              crossRefs.push({ item: critText, substance: sub, explanation: 'This is especially critical when working with ' + sub + '.' });
            }
          }
        });
      }
      if (subData && subData.dietNote) {
        var fastItem = safetyStates.find(function(s) { return s.text.indexOf('Fasted') !== -1; });
        if (fastItem && !fastItem.checked) {
          crossRefs.push({ item: 'Dietary preparation', substance: sub, explanation: subData.dietNote });
        }
      }

      // ── Determine tier ──
      var hasCriticalWarnings = warnings.length > 2 || (sub === '5-MeO-DMT' && sitter === 'No — solo');
      var tier;
      if (hasCriticalWarnings || pct < 40) tier = 'review';
      else if (warnings.length === 0 && pct >= 80) tier = 'ready';
      else tier = 'prepare';

      var tierLabels = { ready: 'Well-Prepared', prepare: 'Nearly Ready', review: 'Needs Attention' };

      // ── Build HTML ──
      var html = '';
      html += '<div class="jp-out-badge tier-' + tier + '">' + tierLabels[tier] + ' — ' + pct + '% complete</div>';

      // Warnings
      if (warnings.length > 0) {
        html += '<div class="jp-out-section jp-out-warnings">';
        html += '<div class="jp-out-label">⚠ Attention</div>';
        warnings.forEach(function(w) { html += '<div class="jp-out-warn">' + w + '</div>'; });
        html += '</div>';
      }

      // Substance-specific guidance
      if (subData) {
        html += '<div class="jp-out-section">';
        html += '<div class="jp-out-label">Substance Guidance</div>';
        html += '<div class="jp-out-sub-guidance">';
        html += '<strong>' + sub + '</strong> — ' + subData.duration + ' duration, ' + subData.onset + ' onset';
        html += '<ul>';
        subData.points.forEach(function(p) { html += '<li>' + p + '</li>'; });
        html += '</ul>';
        html += '</div></div>';
      }

      // Substance & Dose
      html += '<div class="jp-out-section"><div class="jp-out-label">Substance &amp; Dose</div><div class="jp-out-value">';
      html += sub ? '<strong>' + sub + '</strong>' : '<em>Not selected</em>';
      if (dose) html += ' — ' + dose;
      if (exp) html += '<br>Experience level: ' + exp;
      if (source) html += '<br>Verification: ' + source;
      html += '</div></div>';

      // Intention
      var hasIntention = intention || explore || outcome || release;
      if (hasIntention) {
        html += '<div class="jp-out-section"><div class="jp-out-label">Intention &amp; Inner Work</div><div class="jp-out-value">';
        if (intention) html += '<strong>Motivation:</strong> ' + intention.replace(/\n/g, '<br>') + '<br><br>';
        if (explore) html += '<strong>Exploring:</strong> ' + explore.replace(/\n/g, '<br>') + '<br><br>';
        if (outcome) html += '<strong>Hoped-for outcome:</strong> ' + outcome.replace(/\n/g, '<br>') + '<br><br>';
        if (release) html += '<strong>Letting go of:</strong> ' + release.replace(/\n/g, '<br>');
        html += '</div></div>';
      }

      if (fears) {
        html += '<div class="jp-out-section"><div class="jp-out-label">Fears &amp; Concerns</div><div class="jp-out-value">' + fears.replace(/\n/g, '<br>') + '</div></div>';
      }

      // Set & Setting
      html += '<div class="jp-out-section"><div class="jp-out-label">Set &amp; Setting</div><div class="jp-out-value">';
      if (location) html += '<strong>Location:</strong> ' + location + '<br>';
      if (sitter) html += '<strong>Sitter:</strong> ' + sitter + '<br>';
      if (date) {
        var d = new Date(date);
        var dateStr = d.toLocaleDateString('en-GB', { weekday:'long', year:'numeric', month:'long', day:'numeric' });
        html += '<strong>Date:</strong> ' + dateStr + '<br>';
        var today2 = new Date(); today2.setHours(0,0,0,0);
        var diff2 = Math.ceil((d - today2) / (1000*60*60*24));
        if (diff2 > 0) html += '<strong>Preparation time remaining:</strong> ' + diff2 + ' day' + (diff2===1?'':'s') + '<br>';
      }
      html += '<strong>Setting preparation:</strong> ' + sc.c + ' of ' + sc.t + ' items complete';
      if (sc.c < sc.t) html += ' — <em>' + (sc.t - sc.c) + ' remaining</em>';
      html += '</div></div>';

      // Safety
      html += '<div class="jp-out-section"><div class="jp-out-label">Safety</div><div class="jp-out-value">';
      html += '<strong>Safety checklist:</strong> ' + saf.c + ' of ' + saf.t + ' items complete';
      if (saf.c === saf.t) html += ' — <em style="color:#6dd456;">All safety items addressed</em>';
      else html += ' — <em style="color:#c9943a;">' + (saf.t - saf.c) + ' items need attention</em>';
      html += '</div></div>';

      // Integration
      html += '<div class="jp-out-section"><div class="jp-out-label">Integration</div><div class="jp-out-value">';
      html += '<strong>Integration checklist:</strong> ' + intg.c + ' of ' + intg.t + ' items complete';
      if (intg.c < intg.t) html += ' — <em>' + (intg.t - intg.c) + ' remaining</em>';
      html += '</div></div>';

      // Overall
      html += '<div class="jp-out-section"><div class="jp-out-label">Overall Preparation</div><div class="jp-out-value">';
      html += '<strong>' + pct + '%</strong> of all checklist items completed (' + totalC + ' of ' + totalT + ')';
      html += '</div></div>';
      html += '<div class="jp-out-bar"><div class="jp-out-bar-fill" style="width:' + pct + '%"></div></div>';

      // ── PERSONALISED RECOMMENDATIONS ──
      var recs = [];

      // Cross-reference gaps (substance-specific)
      crossRefs.forEach(function(cr) {
        recs.push({ critical: true, title: cr.item + ' (critical for ' + cr.substance + ')', body: cr.explanation });
      });

      // Unchecked safety items
      safetyStates.forEach(function(item, idx) {
        if (!item.checked && SAFETY_EXPLANATIONS[idx]) {
          var alreadyCrossRef = crossRefs.some(function(cr) { return item.text.indexOf(cr.item) !== -1; });
          if (!alreadyCrossRef) {
            recs.push({ critical: false, title: item.text, body: SAFETY_EXPLANATIONS[idx].explanation });
          }
        }
      });

      // Unchecked integration items
      integrationStates.forEach(function(item, idx) {
        if (!item.checked && INTEGRATION_EXPLANATIONS[idx]) {
          recs.push({ critical: false, title: item.text, body: INTEGRATION_EXPLANATIONS[idx].explanation });
        }
      });

      if (recs.length > 0) {
        html += '<div class="jp-out-recs">';
        html += '<div class="jp-out-rec-title">Personalised Recommendations</div>';
        recs.forEach(function(r) {
          html += '<div class="jp-out-rec-item' + (r.critical ? ' is-critical' : '') + '">';
          html += '<strong>' + r.title + '</strong>';
          html += r.body;
          html += '</div>';
        });
        html += '</div>';
      }

      // ── SUGGESTED RESOURCES ──
      var resources = [];
      if (subData) resources.push({ href: subData.guide + '/', text: subData.guideName });
      if (saf.c < saf.t) {
        resources.push({ href: '/readiness/', text: 'Readiness Assessment' });
        resources.push({ href: '/checker/', text: 'Interaction Checker' });
      }
      if (intg.c < intg.t) resources.push({ href: '/integration/', text: 'Integration Guide' });
      if (!intention && !explore) resources.push({ href: '/preparation/', text: 'Preparation Guide' });

      if (resources.length > 0) {
        html += '<div class="jp-out-resources">';
        html += '<div class="jp-out-rec-title">Suggested Resources</div>';
        resources.forEach(function(r) { html += '<a href="' + r.href + '">' + r.text + ' →</a>'; });
        html += '</div>';
      }

      // ── NEXT STEPS ──
      html += '<div class="jp-out-section"><div class="jp-out-label">Next Steps</div><div class="jp-out-value">';
      if (tier === 'review') {
        html += 'Review the warnings and recommendations above before proceeding. Address outstanding safety items as a priority. Return to the relevant steps to complete your preparation.';
      } else if (tier === 'prepare') {
        html += 'You are nearly there. Address any remaining recommendations and spend time with your intention in the days ahead. Complete unchecked safety items before your session.';
      } else {
        html += 'Your preparation looks strong. In the days ahead, continue to sit with your intention, finalise your setting, and take care of your body and mind. Trust what you have built here.';
      }
      html += '</div></div>';

      document.getElementById('jp-output').innerHTML = html;
      showPanel(5);
    });

    document.getElementById('jp-edit-back').addEventListener('click', function() { showPanel(4); });
  })();
  </script>


  <!-- PDF Generation & Email Capture -->
  <script is:inline data-astro-rerun>
  (function() {
