      'Ayahuasca': { duration: '4-6 hours', onset: '20-60 minutes', points: ['Tyramine-free diet required 24-48hrs before (no aged cheese, cured meats, fermented foods).', 'MAOI interactions are life-threatening. Check all medications.', 'Purging is common and expected.', 'Should be taken with experienced facilitation.'], guide: '/ayahuasca', guideName: 'Ayahuasca Guide' },
      'Mescaline (cactus)': { duration: '8-12 hours', onset: '45-120 minutes', points: ['Very long experience - plan full day.', 'Nausea common in first 1-2 hours.', 'Slow onset - wait at least 2 hours before considering redose.', 'Significant body load. Stay hydrated.'], guide: '/mescaline', guideName: 'Mescaline Guide' },
      '5-MeO-DMT': { duration: '15-45 minutes', onset: 'Seconds', points: ['One of most powerful psychedelics. Experienced sitter non-negotiable.', 'Complete ego dissolution common. May thrash or vocalise.', 'Never combine with MAOIs or any other substance.', 'Requires significant psychological preparation.'], guide: '/fivemedmt', guideName: '5-MeO-DMT Guide' },
      'MDMA': { duration: '3-5 hours', onset: '30-60 minutes', points: ['Stay hydrated but do not overhydrate (250ml/hour).', 'Monitor body temperature. Overheating is serious risk.', 'Never exceed 1.5mg/kg bodyweight.', '3-month minimum between uses.'], guide: '/mdma', guideName: 'MDMA Guide' },
      'Ketamine': { duration: '45-90 minutes', onset: 'Minutes', points: ['Dissociative, not classical psychedelic.', 'Do not combine with alcohol, opioids, or benzodiazepines.', 'Low doses psychedelic; high doses full dissociation.', 'Bladder damage with frequent use.'], guide: '/ketamine', guideName: 'Ketamine Guide' },
      '2C-B': { duration: '4-6 hours', onset: '45-75 minutes (oral)', points: ['Strongly dose-sensitive: 5mg difference changes experience dramatically.', 'Has stimulant and empathogenic properties.', 'Nasal administration extremely painful. Oral recommended.', 'Start with 15-18mg oral for first experience.'], guide: '/twocb', guideName: '2C-B Guide' }
    };

    var SAFETY_EXPLANATIONS = [
      'Unscreened medical conditions can cause dangerous reactions. Complete the Readiness Assessment.',
      'Some drug combinations are life-threatening (SSRIs + MDMA, lithium + psychedelics, MAOIs + many substances).',
      'Unverified substances may contain dangerous adulterants or wrong compounds. Reagent test first.',
      'Estimating doses leads to unexpectedly intense experiences. Use a milligram scale.',
      'Your sitter needs this information to support you and know what is within normal range.',
      'Difficult experiences require calm, grounding presence. Brief your sitter on what to do.',
      'If something goes wrong, someone outside the situation should know how to be reached.',
      'A benzodiazepine can reduce a difficult psychedelic experience within 20-30 minutes.',
      'Combinations multiply unpredictability and risk. Cannabis can dramatically intensify psychedelics.',
      'A full stomach increases nausea and can reduce or delay absorption.'
    ];

    var INTEGRATION_EXPLANATIONS = [
      'Insights fade quickly. Even brief notes within the first hours can be invaluable weeks later.',
      'Integration requires psychological space. Major decisions should wait until you have processed.',
      'Verbalising with a trusted listener helps consolidate meaning.',
      'Professional support can be essential if difficult material surfaces.',
      'Nature contact supports integration of expanded awareness.',
      'Structured practices prevent insights from dissolving back into daily autopilot.',
      'Alcohol and cannabis can blur the integration window and reintroduce avoidance patterns.',
      'Embodied practices help ground insights in the body rather than keeping them conceptual.'
    ];

    // ── Helpers ──
    function val(id) {
      var el = document.getElementById(id);
      return el ? (el.value || '') : '';
    }

    function getChecklistItems(listId) {
      var list = document.getElementById(listId);
      if (!list) return [];
      var items = [];
      list.querySelectorAll('.jp-check-item').forEach(function(item) {
        var cb = item.querySelector('input[type="checkbox"]');
        var spans = item.querySelectorAll('span');
        var text = spans[spans.length - 1].textContent.trim();
        items.push({ checked: cb.checked, text: text });
      });
      return items;
    }

    function countChecked(listId) {
      var el = document.getElementById(listId);
      if (!el) return { c: 0, t: 0 };
      return {
        c: el.querySelectorAll('input:checked').length,
        t: el.querySelectorAll('input[type="checkbox"]').length
      };
    }

    // ── PDF Generation ──
    function generatePDF() {
      var jsPDF = window.jspdf.jsPDF;
      var doc = new jsPDF({ unit: 'mm', format: 'a4' });

      var pageW = 210, pageH = 297;
      var ml = 22, mr = 22, cw = pageW - ml - mr;
      var y = 22, pageNum = 1;

      var cTeal = [62, 201, 191];
      var cGreen = [92, 184, 74];
      var cDark = [30, 30, 30];
      var cBody = [80, 80, 80];
      var cMuted = [140, 140, 140];
      var cAmber = [201, 148, 58];
      var cLight = [220, 220, 220];

      // Sanitise text for jsPDF (built-in fonts lack Unicode support)
      function clean(str) {
        if (!str) return '';
        return str
          .replace(/['‘’ʼ]/g, "'")
          .replace(/["“”]/g, '"')
          .replace(/—/g, ' - ')
          .replace(/–/g, '-')
          .replace(/→/g, '->')
          .replace(/…/g, '...')
          .replace(/ /g, ' ');
      }

      function lh(fontSize) { return fontSize * 0.42; }

      function checkBreak(needed) {
        if (y + needed > pageH - 22) {
          addPageFooter();
          doc.addPage();
          pageNum++;
          y = 22;
        }
      }

      function addPageFooter() {
        doc.setFontSize(7);
        doc.setFont('helvetica', 'normal');
        doc.setTextColor(cMuted[0], cMuted[1], cMuted[2]);
        doc.text('This plan is for personal reference only. It does not constitute medical or clinical advice.', pageW / 2, pageH - 14, { align: 'center' });
        doc.text('howtousepsychedelics.com  |  Psygaia', pageW / 2, pageH - 10, { align: 'center' });
        doc.text('Page ' + pageNum, pageW - mr, pageH - 10, { align: 'right' });
      }

      function drawLine(yPos, color) {
        doc.setDrawColor(color[0], color[1], color[2]);
        doc.setLineWidth(0.3);
        doc.line(ml, yPos, pageW - mr, yPos);
      }

      function sectionLabel(text) {
        checkBreak(12);
        doc.setFontSize(8);
        doc.setFont('helvetica', 'bold');
        doc.setTextColor(cTeal[0], cTeal[1], cTeal[2]);
        doc.text(text.toUpperCase(), ml, y);
        y += 6;
      }

      function bodyText(text, options) {
        if (!text) return;
        var opts = options || {};
        var fontSize = opts.fontSize || 10;
        var color = opts.color || cBody;
        var style = opts.style || 'normal';
        var indent = opts.indent || 0;
        doc.setFontSize(fontSize);
        doc.setFont('helvetica', style);
        doc.setTextColor(color[0], color[1], color[2]);
        var lines = doc.splitTextToSize(clean(text), cw - indent);
        var lineHeight = lh(fontSize);
        for (var i = 0; i < lines.length; i++) {
          checkBreak(lineHeight);
          doc.text(lines[i], ml + indent, y);
          y += lineHeight;
        }
      }

      function labelValue(label, value) {
        if (!value) return;
        checkBreak(6);
        doc.setFontSize(10);
        doc.setFont('helvetica', 'bold');
        doc.setTextColor(cDark[0], cDark[1], cDark[2]);
        var labelW = doc.getTextWidth(label + ': ');
        doc.text(label + ': ', ml, y);
        doc.setFont('helvetica', 'normal');
        doc.setTextColor(cBody[0], cBody[1], cBody[2]);
        var remaining = doc.splitTextToSize(clean(value), cw - labelW);
        doc.text(remaining[0], ml + labelW, y);
        y += lh(10);
        for (var i = 1; i < remaining.length; i++) {
          checkBreak(lh(10));
          doc.text(remaining[i], ml + labelW, y);
          y += lh(10);
        }
      }

      function checklist(items) {
        for (var i = 0; i < items.length; i++) {
          checkBreak(6);
          var marker = items[i].checked ? '[x]' : '[ ]';
          doc.setFontSize(10);
          doc.setFont('helvetica', 'normal');
          if (items[i].checked) {
            doc.setTextColor(cGreen[0], cGreen[1], cGreen[2]);
          } else {
            doc.setTextColor(cMuted[0], cMuted[1], cMuted[2]);
          }
          doc.text(marker, ml + 2, y);
          doc.setTextColor(cBody[0], cBody[1], cBody[2]);
          var lines = doc.splitTextToSize(clean(items[i].text), cw - 12);
          for (var j = 0; j < lines.length; j++) {
            if (j > 0) checkBreak(lh(10));
            doc.text(lines[j], ml + 10, y);
            if (j < lines.length - 1) y += lh(10);
          }
          y += lh(10) + 1;
        }
      }

      // ── Gather Data ──
      var sub = val('pl-sub');
      var dose = val('pl-dose');
      var exp = val('pl-exp');
      var source = val('pl-source');
      var intention = val('pl-intent-text');
      var explore = val('pl-explore');
      var fears = val('pl-fears');
      var outcome = val('pl-outcome');
      var release = val('pl-release');
      var location = val('pl-location');
      var sitter = val('pl-sitter');
      var dateVal = val('pl-date');
      var settingItems = getChecklistItems('jp-setting-list');
      var safetyItems = getChecklistItems('jp-safety-list');
      var integrationItems = getChecklistItems('jp-integration-list');
      var sc = countChecked('jp-setting-list');
      var saf = countChecked('jp-safety-list');
      var intg = countChecked('jp-integration-list');
      var totalC = sc.c + saf.c + intg.c;
      var totalT = sc.t + saf.t + intg.t;
      var pct = totalT > 0 ? Math.round((totalC / totalT) * 100) : 0;

      // Warnings
      var warnings = [];
      if (source === 'Unverified') warnings.push('Your substance is unverified. Reagent testing is strongly recommended.');
      if (exp === 'First time ever' && (dose === 'High dose (strong)' || dose === 'Heroic dose (very high)')) warnings.push('A high or heroic dose for a first experience carries significantly elevated risk.');
      if (sitter === 'No — solo' && exp === 'First time ever') warnings.push('Solo use for a first experience is strongly discouraged.');
      if ((dose === 'High dose (strong)' || dose === 'Heroic dose (very high)') && sitter === 'No — solo') warnings.push('High-dose experiences without a sitter present substantial safety risk.');
      if (sub === '5-MeO-DMT' && sitter === 'No — solo') warnings.push('5-MeO-DMT should never be taken without an experienced sitter.');
      if (sub === 'Ayahuasca' && sitter === 'No — solo') warnings.push('Ayahuasca should be taken with experienced facilitation.');
      if (!intention && !explore) warnings.push('No intention written. Consider clarifying your intention before proceeding.');
      if (dose === 'Unsure') warnings.push('Dose is uncertain. Research thoroughly and start conservatively.');

      var hasCriticalWarnings = warnings.length > 2 || (sub === '5-MeO-DMT' && sitter === 'No — solo');
      var tier = hasCriticalWarnings || pct < 40 ? 'Needs Attention' : (warnings.length === 0 && pct >= 80) ? 'Well-Prepared' : 'Nearly Ready';

      // ── Build PDF ──

      // Logo
      var logoW = 32.3, logoH = logoW * (200 / 800);
      try {
        if (psygaiaLogo.complete && psygaiaLogo.naturalWidth > 0) {
          doc.addImage(psygaiaLogo, 'PNG', ml, y, logoW, logoH);
        }
      } catch(e) {}
      y += logoH + 12;

      // Title
      doc.setFontSize(22);
      doc.setFont('helvetica', 'bold');
      doc.setTextColor(cDark[0], cDark[1], cDark[2]);
      doc.text('Journey Preparation Plan', ml, y);
      y += 8;

      // Subtitle
      doc.setFontSize(9);
      doc.setFont('helvetica', 'normal');
      doc.setTextColor(cMuted[0], cMuted[1], cMuted[2]);
      var now = new Date();
      var dateStr = now.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
      doc.text('Generated ' + dateStr + '  |  howtousepsychedelics.com  |  Psygaia', ml, y);
      y += 10;

      drawLine(y, cLight);
      y += 8;

      // Tier badge
      doc.setFontSize(11);
      doc.setFont('helvetica', 'bold');
      if (tier === 'Well-Prepared') doc.setTextColor(cGreen[0], cGreen[1], cGreen[2]);
      else if (tier === 'Nearly Ready') doc.setTextColor(cTeal[0], cTeal[1], cTeal[2]);
      else doc.setTextColor(cAmber[0], cAmber[1], cAmber[2]);
      doc.text(tier + ' - ' + pct + '% complete', ml, y);
      y += 10;

      // Warnings
      if (warnings.length > 0) {
        doc.setFontSize(8);
        doc.setFont('helvetica', 'bold');
        doc.setTextColor(cAmber[0], cAmber[1], cAmber[2]);
        doc.text('ATTENTION', ml, y);
        y += 5;
        for (var w = 0; w < warnings.length; w++) {
          doc.setFontSize(9);
          doc.setFont('helvetica', 'normal');
          doc.setTextColor(cAmber[0], cAmber[1], cAmber[2]);
          var wLines = doc.splitTextToSize('- ' + clean(warnings[w]), cw);
          for (var wl = 0; wl < wLines.length; wl++) {
            checkBreak(4);
            doc.text(wLines[wl], ml, y);
            y += 4;
          }
          y += 1;
        }
        y += 4;
        drawLine(y, cLight);
        y += 8;
      }

      // ── SUBSTANCE GUIDANCE ──
      var subData = SUBSTANCE_DATA[sub];
      if (subData) {
        sectionLabel('Substance Guidance');
        bodyText(sub + ' - Duration: ' + subData.duration + ', Onset: ' + subData.onset, { fontSize: 10, style: 'bold', color: cDark });
        y += 2;
        for (var sp = 0; sp < subData.points.length; sp++) {
          bodyText('• ' + subData.points[sp], { fontSize: 9, indent: 3 });
          y += 1;
        }
        y += 3;
        drawLine(y, cLight);
        y += 8;
      }

      // ── SUBSTANCE & DOSE ──
      sectionLabel('Substance & Dose');
      if (sub) labelValue('Substance', sub);
      if (dose) labelValue('Dose level', dose);
      if (exp) labelValue('Experience level', exp);
      if (source) labelValue('Verification', source);
      y += 4;
      drawLine(y, cLight);
      y += 8;

      // ── INTENTION ──
      var hasIntention = intention || explore || outcome || release;
      if (hasIntention) {
        sectionLabel('Intention & Inner Work');
        if (intention) {
          bodyText('Motivation:', { style: 'bold', color: cDark, fontSize: 10 });
          y += 1;
          bodyText(intention, { fontSize: 10 });
          y += 3;
        }
        if (explore) {
          bodyText('Exploring:', { style: 'bold', color: cDark, fontSize: 10 });
          y += 1;
          bodyText(explore, { fontSize: 10 });
          y += 3;
        }
        if (outcome) {
          bodyText('Hoped-for outcome:', { style: 'bold', color: cDark, fontSize: 10 });
          y += 1;
          bodyText(outcome, { fontSize: 10 });
          y += 3;
        }
        if (release) {
          bodyText('Letting go of:', { style: 'bold', color: cDark, fontSize: 10 });
          y += 1;
          bodyText(release, { fontSize: 10 });
          y += 3;
        }
        y += 1;
        drawLine(y, cLight);
        y += 8;
      }

      // ── FEARS ──
      if (fears) {
        sectionLabel('Fears & Concerns');
        bodyText(fears, { fontSize: 10 });
        y += 4;
        drawLine(y, cLight);
        y += 8;
      }

      // ── SET & SETTING ──
      sectionLabel('Set & Setting');
      if (location) labelValue('Location', location);
      if (sitter) labelValue('Sitter', sitter);
      if (dateVal) {
        var dObj = new Date(dateVal);
        var dStr = dObj.toLocaleDateString('en-GB', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
        labelValue('Date', dStr);
        var today = new Date(); today.setHours(0,0,0,0);
        var dDiff = Math.ceil((dObj - today) / (1000*60*60*24));
        if (dDiff > 0) labelValue('Preparation time remaining', dDiff + ' day' + (dDiff === 1 ? '' : 's'));
      }
      y += 3;
      bodyText('Setting Checklist (' + sc.c + ' of ' + sc.t + ' complete):', { style: 'bold', color: cDark, fontSize: 10 });
      y += 2;
      checklist(settingItems);
      y += 2;
      drawLine(y, cLight);
      y += 8;

      // ── SAFETY ──
      sectionLabel('Safety');
      bodyText('Safety Checklist (' + saf.c + ' of ' + saf.t + ' complete):', { style: 'bold', color: cDark, fontSize: 10 });
      y += 2;
      checklist(safetyItems);
      y += 2;
      drawLine(y, cLight);
      y += 8;

      // ── INTEGRATION ──
      sectionLabel('Integration');
      bodyText('Integration Checklist (' + intg.c + ' of ' + intg.t + ' complete):', { style: 'bold', color: cDark, fontSize: 10 });
      y += 2;
      checklist(integrationItems);
      y += 2;
      drawLine(y, cLight);
      y += 8;

      // ── PERSONALISED RECOMMENDATIONS ──
      var hasRecs = false;
      var uncheckedSafety = [];
      safetyItems.forEach(function(item, idx) {
        if (!item.checked && SAFETY_EXPLANATIONS[idx]) {
          uncheckedSafety.push({ text: item.text, explanation: SAFETY_EXPLANATIONS[idx] });
        }
      });
      var uncheckedIntegration = [];
      integrationItems.forEach(function(item, idx) {
        if (!item.checked && INTEGRATION_EXPLANATIONS[idx]) {
          uncheckedIntegration.push({ text: item.text, explanation: INTEGRATION_EXPLANATIONS[idx] });
        }
      });

      if (uncheckedSafety.length > 0 || uncheckedIntegration.length > 0) {
        hasRecs = true;
        sectionLabel('Personalised Recommendations');

        if (uncheckedSafety.length > 0) {
          bodyText('Safety items to address:', { style: 'bold', color: cDark, fontSize: 10 });
          y += 2;
          for (var us = 0; us < uncheckedSafety.length; us++) {
            checkBreak(10);
            doc.setFontSize(9);
            doc.setFont('helvetica', 'bold');
            doc.setTextColor(cAmber[0], cAmber[1], cAmber[2]);
            doc.text(clean('• ' + uncheckedSafety[us].text), ml + 3, y);
            y += lh(9) + 1;
            bodyText(uncheckedSafety[us].explanation, { fontSize: 8, color: cBody, indent: 6 });
            y += 2;
          }
          y += 3;
        }

        if (uncheckedIntegration.length > 0) {
          bodyText('Integration items to consider:', { style: 'bold', color: cDark, fontSize: 10 });
          y += 2;
          for (var ui = 0; ui < uncheckedIntegration.length; ui++) {
            checkBreak(10);
            doc.setFontSize(9);
            doc.setFont('helvetica', 'bold');
            doc.setTextColor(cTeal[0], cTeal[1], cTeal[2]);
            doc.text(clean('• ' + uncheckedIntegration[ui].text), ml + 3, y);
            y += lh(9) + 1;
            bodyText(uncheckedIntegration[ui].explanation, { fontSize: 8, color: cBody, indent: 6 });
            y += 2;
          }
          y += 3;
        }

        drawLine(y, cLight);
        y += 8;
      }

      // ── OVERALL ──
      sectionLabel('Overall Preparation');
      checkBreak(14);
      doc.setFillColor(cLight[0], cLight[1], cLight[2]);
      doc.roundedRect(ml, y, cw, 5, 2.5, 2.5, 'F');
      if (pct > 0) {
        doc.setFillColor(cTeal[0], cTeal[1], cTeal[2]);
        var fillW = Math.max(5, (cw * pct) / 100);
        doc.roundedRect(ml, y, fillW, 5, 2.5, 2.5, 'F');
      }
      y += 9;
      bodyText(pct + '% of all checklist items completed (' + totalC + ' of ' + totalT + ')', { fontSize: 10, color: cDark, style: 'bold' });
      y += 4;
      drawLine(y, cLight);
      y += 8;

      // ── NEXT STEPS ──
      sectionLabel('Next Steps');
      var nextText;
      if (tier === 'Needs Attention') {
        nextText = 'Review the warnings and recommendations above before proceeding. Address outstanding safety items as a priority. Return to the planner to complete your preparation.';
      } else if (tier === 'Nearly Ready') {
        nextText = 'You are nearly there. Address any remaining recommendations and spend time with your intention in the days ahead. Complete unchecked safety items before your session.';
      } else {
        nextText = 'Your preparation looks strong. In the days ahead, continue to sit with your intention, finalise your setting, and take care of your body and mind. Trust what you have built here.';
      }
      bodyText(nextText, { fontSize: 10 });
      y += 4;

      // Suggested resources
      bodyText('Resources: howtousepsychedelics.com', { fontSize: 9, color: cMuted });
      if (subData) bodyText('Substance guide: howtousepsychedelics.com' + subData.guide, { fontSize: 9, color: cTeal });
      if (saf.c < saf.t) bodyText('Readiness Assessment: howtousepsychedelics.com/readiness', { fontSize: 9, color: cTeal });
      if (intg.c < intg.t) bodyText('Integration Guide: howtousepsychedelics.com/integration', { fontSize: 9, color: cTeal });

      addPageFooter();
      doc.save('journey-preparation-plan.pdf');
    }

    // ── Form Submission (fire-and-forget pattern) ──
    pdfForm.addEventListener('submit', function(e) {
      e.preventDefault();
      pdfError.style.display = 'none';

      var email = pdfForm.email.value.trim();
      var firstName = pdfForm.first_name.value.trim();
      var hp = pdfForm._hp.value;

      if (!email) {
        pdfError.textContent = 'Please enter your email.';
        pdfError.style.display = 'block';
        return;
      }

      pdfBtn.disabled = true;
      pdfBtnText.textContent = 'Preparing your PDF...';

      // Fire-and-forget subscribe
      fetch('/.netlify/functions/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email, first_name: firstName, _hp: hp, source: 'htup-planner' }),
      }).catch(function() {});

      // Generate PDF immediately
      try {
        generatePDF();
        pdfSection.style.display = 'none';
        pdfSuccess.style.display = 'block';
      } catch (err) {
        console.error('PDF generation error:', err);
        pdfError.textContent = 'PDF generation failed. Please try again.';
        pdfError.style.display = 'block';
        pdfBtn.disabled = false;
        pdfBtnText.textContent = 'Download Plan as PDF →';
      }
    });
  })();
  </script>


</Base>
