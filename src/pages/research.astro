const sorted = studies.slice().sort((a, b) => b.year - a.year);
---

<Base
  title="Research Library — How to Use Psychedelics"
  description="A curated library of landmark psychedelic studies — psilocybin, MDMA, LSD, ketamine, ayahuasca, ibogaine, and microdosing research — with plain-language summaries and links to every original paper."
  canonicalPath="/research"
>

  <div class="content-page">

    <!-- Content Hero -->
    <div class="content-hero">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span class="breadcrumb-sep">/</span>
        <a href="/foundations/">Foundations</a>
        <span class="breadcrumb-sep">/</span>
        <span>Research Library</span>
      </div>
      <p class="content-hero-updated">Updated &middot; July 2026 &middot; {studies.length} studies</p>
      <h1 class="content-hero-title">Research Library</h1>
      <p class="content-hero-subtitle">The studies that actually moved the field — landmark trials, foundational safety work, and the honest null results — each summarized in plain language and linked to the original paper. Curated for signal, not volume.</p>
    </div>

    <div class="research-listing">

      <div class="content-callout">
        <div class="callout-label">How to read this library</div>
        <p>Clinical trials happen under careful screening, calibrated doses, and professional support — conditions that don't transfer automatically to other contexts. Positive findings are evidence of what's possible under those conditions, not a promise. We include null and cautionary results deliberately.</p>
      </div>

      <!-- Substance filter -->
      <div class="blog-pills" id="researchPills">
        {substances.map(s => (
          <button class={`blog-pill${s === 'All' ? ' active' : ''}`} data-substance={s}>{s}</button>
        ))}
      </div>

      <!-- Study cards -->
      <div class="research-grid" id="researchGrid">
        {sorted.map(s => (
          <a class="research-card" href={`https://doi.org/${s.doi}`} target="_blank" rel="noopener" data-substance={s.substance}>
            <div class="research-card-tags">
              <span class="blog-card-category">{s.substance}</span>
              <span class="research-card-topic">{s.topic}</span>
              <span class="research-card-year">{s.year}</span>
            </div>
            <h3 class="research-card-title">{s.title}</h3>
            <p class="research-card-finding">{s.finding}</p>
            <div class="research-card-meta">
              <span>{s.authors}</span>
              <span class="blog-meta-sep">&middot;</span>
              <em>{s.journal}</em>
              <span class="research-card-doi">DOI →</span>
            </div>
          </a>
        ))}
      </div>

      <div class="blog-empty" id="researchEmpty" style="display:none;">
        <p>No studies for this filter yet.</p>
      </div>

    </div>

    <!-- Disclaimer -->
    <div class="disclaimer-bar"><p>Harm reduction education only. Summaries simplify; always read the original paper before drawing conclusions.</p></div>

    <!-- Support Banner -->
    <div class="footer-support">
      <div class="footer-support-inner">
        <div class="footer-support-text">
          <p class="footer-support-label">Support Psychedelic Research &amp; Education</p>
          <p class="footer-support-headline">This work exists because people like you care.</p>
          <p class="footer-support-body">Psygaia is an independent nonprofit — no ads, no corporate sponsors. Just rigorous, freely available education in service of safer psychedelic practice and planetary health. Your support keeps this work alive.</p>
        </div>
        <a class="footer-support-btn" href="https://buy.stripe.com/bIYcMX3W893Z4o04gg" target="_blank" rel="noopener">Support This Work →</a>
      </div>
    </div>

  </div>

  <!-- Substance Filter Script -->
  <script is:inline data-astro-rerun>
    (function() {
      var pills = document.querySelectorAll('#researchPills .blog-pill');
      var cards = document.querySelectorAll('.research-card');
      var empty = document.getElementById('researchEmpty');

      function applyFilter(pill) {
        pills.forEach(function(p) { p.classList.remove('active'); });
        pill.classList.add('active');
        var sub = pill.getAttribute('data-substance');
        var visible = 0;
        cards.forEach(function(card) {
          if (sub === 'All' || card.getAttribute('data-substance') === sub) {
            card.style.display = '';
            visible++;
          } else {
            card.style.display = 'none';
          }
        });
        empty.style.display = visible === 0 ? '' : 'none';
      }

      pills.forEach(function(pill) {
        pill.addEventListener('click', function() { applyFilter(pill); });
      });

      // Deep link: /research/?substance=Psilocybin pre-selects a filter
      var param = new URLSearchParams(window.location.search).get('substance');
      if (param) {
        pills.forEach(function(pill) {
          if (pill.getAttribute('data-substance').toLowerCase() === param.toLowerCase()) applyFilter(pill);
        });
      }
    })();
  </script>

</Base>
