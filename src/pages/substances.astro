---
import Base from '../layouts/Base.astro';
import { substances } from '../data/substances';

// One comparison row per substance route, on a shared square-root
// time axis (keeps DMT's 20 minutes and ibogaine's 48 hours legible
// on the same chart).
const AXIS_MAX_H = 48;
const sqrtPct = (h: number) => Math.sqrt(h / AXIS_MAX_H) * 100;

const rows = Object.values(substances)
  .flatMap((sub) =>
    sub.routes.map((r) => {
      const endInUnit = r.phases[r.phases.length - 1].to;
      const hours = r.unit === 'min' ? endInUnit / 60 : endInUnit;
      return {
        name: sub.name,
        url: `/${sub.id}/`,
        route: r.name,
        multiRoute: sub.routes.length > 1,
        hours,
        label: r.total,
        pct: sqrtPct(hours),
      };
    })
  )
  .sort((a, b) => a.hours - b.hours);

const ticks = [
  { h: 0.25, label: '15m' },
  { h: 1, label: '1h' },
  { h: 4, label: '4h' },
  { h: 12, label: '12h' },
  { h: 24, label: '24h' },
  { h: 48, label: '48h' },
].map((t) => ({ ...t, pct: sqrtPct(t.h) }));
---

<Base
  title="Substance Guides — How to Use Psychedelics"
  description="Each psychedelic substance has a distinct pharmacological profile, phenomenological character, cultural history, and risk profile. Choose a substance to explore."
  canonicalPath="/substances"
  hideProgress={true}
>

  <div class="content-page">

    <!-- Content Hero -->
    <div class="content-hero">
      <!-- Breadcrumb -->
    <div class="breadcrumb">
      <a href="/">Home</a>
      <span class="breadcrumb-sep">/</span>
      <span>Substances</span>
    </div>
      <h1 class="content-hero-title">Substance Guides</h1>
      <p class="content-hero-subtitle">Each psychedelic substance has a distinct pharmacological profile, phenomenological character, cultural history, and risk profile. Choose a substance to explore.</p>
    </div>

    <!-- Hub Grid -->
    <div class="hub-grid">
      <a href="/psilocybin/" class="hub-card">
        <div class="card-num">01</div>
        <h3>Psilocybin Mushrooms</h3>
        <p>The most researched psychedelic. Effects, dosage, evidence, risks.</p>
        <div class="card-arrow">Read &rarr;</div>
      </a>
      <a href="/ayahuasca/" class="hub-card">
        <div class="card-num">02</div>
        <h3>Ayahuasca</h3>
        <p>Sacred Amazonian brew. Ceremony, preparation, cultural context, MAOI interactions.</p>
        <div class="card-arrow">Read &rarr;</div>
      </a>
      <a href="/dmt/" class="hub-card">
        <div class="card-num">03</div>
        <h3>DMT (N,N-DMT)</h3>
        <p>Endogenous tryptamine. Smoked breakthroughs, entity encounters, and its role in ayahuasca.</p>
        <div class="card-arrow">Read &rarr;</div>
      </a>
      <a href="/fivemedmt/" class="hub-card">
        <div class="card-num">04</div>
        <h3>5-MeO-DMT</h3>
        <p>The most potent psychedelic. Total ego dissolution, short duration, toad controversy.</p>
        <div class="card-arrow">Read &rarr;</div>
      </a>
      <a href="/mescaline/" class="hub-card">
        <div class="card-num">05</div>
        <h3>Mescaline</h3>
        <p>Peyote and San Pedro. Effects, cultural significance, ethical considerations.</p>
        <div class="card-arrow">Read &rarr;</div>
      </a>
      <a href="/lsd/" class="hub-card">
        <div class="card-num">06</div>
        <h3>LSD</h3>
        <p>Semi-synthetic serotonergic psychedelic. Long duration, stimulating character, dosage.</p>
        <div class="card-arrow">Read &rarr;</div>
      </a>
      <a href="/ibogaine/" class="hub-card">
        <div class="card-num">07</div>
        <h3>Ibogaine</h3>
        <p>Powerful anti-addiction compound with serious cardiac risks. Bwiti roots, opioid research.</p>
        <div class="card-arrow">Read &rarr;</div>
      </a>
      <a href="/ketamine/" class="hub-card">
        <div class="card-num">08</div>
        <h3>Ketamine</h3>
        <p>Dissociative anesthetic now used clinically for depression. Distinct profile and risks.</p>
        <div class="card-arrow">Read &rarr;</div>
      </a>
      <a href="/mdma/" class="hub-card">
        <div class="card-num">09</div>
        <h3>MDMA</h3>
        <p>Empathogen used in trauma therapy. Neurotoxicity, heart, and dependence considerations.</p>
        <div class="card-arrow">Read &rarr;</div>
      </a>
      <a href="/cannabis/" class="hub-card">
        <div class="card-num">10</div>
        <h3>Cannabis</h3>
        <p>Endocannabinoid pharmacology, psychedelic potential, combinations, and real risks.</p>
        <div class="card-arrow">Read &rarr;</div>
      </a>
      <a href="/twocb/" class="hub-card">
        <div class="card-num">11</div>
        <h3>2C-B</h3>
        <p>Phenethylamine psychedelic. Effects, dose-dependence, preparation.</p>
        <div class="card-arrow">Read &rarr;</div>
      </a>
      <a href="/salvia/" class="hub-card">
        <div class="card-num">12</div>
        <h3>Salvia Divinorum</h3>
        <p>Kappa-opioid agonist. Alien, brief, and disorienting. Mazatec ceremonial roots.</p>
        <div class="card-arrow">Read &rarr;</div>
      </a>
    </div>

    <!-- Duration Comparison -->
    <section class="cmp-section" id="durations" aria-label="Duration comparison">
      <div class="cmp-head">
        <h2 class="content-h2">How Long Does Each Psychedelic Last?</h2>
        <p class="content-p">Total duration of primary effects by route of administration. The time axis is square-root scaled so twenty-minute and two-day journeys stay comparable — each substance page has the full phase-by-phase timeline.</p>
      </div>
      <div class="cmp-chart" data-reveal>
        <div class="cmp-row cmp-row--axis" aria-hidden="true">
          <span class="cmp-name"></span>
          <span class="cmp-track">
            {ticks.map((t) => (
              <i class="cmp-tick" style={`left: ${t.pct}%`}>{t.label}</i>
            ))}
          </span>
        </div>
        {rows.map((r, i) => (
          <a class="cmp-row" href={r.url} style={`--row-i: ${i}`}>
            <span class="cmp-name">{r.name}{r.multiRoute && <em>{r.route.toLowerCase()}</em>}</span>
            <span class="cmp-track">
              {ticks.map((t) => <i class="cmp-gridline" style={`left: ${t.pct}%`}></i>)}
              <span class="cmp-bar" style={`width: ${r.pct}%`}></span>
              <span class="cmp-value" style={`left: calc(${r.pct}% + 10px)`}>{r.label}</span>
            </span>
          </a>
        ))}
      </div>
    </section>

    <!-- Disclaimer -->
    <div class="disclaimer-bar"><p>Harm reduction education only.</p></div>

    <!-- Support Banner -->
    <div class="footer-support">
      <div class="footer-support-inner">
        <div class="footer-support-text">
          <p class="footer-support-label">Support Psychedelic Research &amp; Education</p>
          <p class="footer-support-headline">This work exists because people like you care.</p>
          <p class="footer-support-body">Psygaia is an independent nonprofit — no ads, no corporate sponsors. Just rigorous, freely available education in service of safer psychedelic practice and planetary health. Your support keeps this work alive.</p>
        </div>
        <a class="footer-support-btn" href="https://buy.stripe.com/bIYcMX3W893Z4o04gg" target="_blank" rel="noopener">Support This Work →</a>
      </div>
    </div>

  </div>

</Base>
