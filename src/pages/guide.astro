---
import Base from '../layouts/Base.astro';
---

<Base
  title="The Essential Guide to Psychedelic Journeying — Free from Psygaia"
  description="An ecological and systems-based guide to intentional psychedelic exploration — preparation, navigation, integration, and the Psygaia Framework. Free."
  canonicalPath="/guide"
  hideProgress={true}
  noindex={true}
>

<style is:global>
  .guide-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: calc(var(--nav-h) + 4rem) 1.5rem 6rem;
  }

  .guide-inner {
    width: 100%;
    max-width: var(--max-w);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 6rem;
    align-items: center;
  }

  /* ── LEFT COLUMN ── */
  .guide-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.25rem;
  }

  .guide-heading {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(2.2rem, 4vw, 3.4rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: 1.25rem;
  }

  .guide-heading .grad-text {
    background: var(--grad);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .guide-body {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--text-secondary);
    margin-bottom: 2.5rem;
    max-width: 540px;
  }

  .guide-what-title {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 1rem;
  }

  .guide-what {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .guide-what li {
    display: flex;
    align-items: flex-start;
    gap: 0.9rem;
    font-size: 0.93rem;
    color: var(--text-secondary);
    line-height: 1.55;
  }

  .guide-what li strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  .guide-what-dot {
    flex-shrink: 0;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    margin-top: 0.52em;
  }

  /* ── RIGHT COLUMN ── */
  .guide-form-col {
    background: var(--bg-card);
    border: 1px solid var(--border-hover);
    border-radius: 20px;
    padding: 2.5rem;
  }

  .guide-form-heading {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 0.4rem;
  }

  .guide-form-sub {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 1.75rem;
  }

  .guide-form {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .guide-field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .guide-field label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .guide-field input {
    width: 100%;
    padding: 0.85rem 1.1rem;
    background: var(--bg);
    border: 1px solid var(--border-hover);
    border-radius: 10px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    color: var(--text-primary);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    outline: none;
    box-sizing: border-box;
  }

  .guide-field input::placeholder {
    color: var(--text-tertiary, rgba(255,255,255,0.25));
  }

  [data-theme="light"] .guide-field input::placeholder {
    color: rgba(0,0,0,0.25);
  }

  .guide-field input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-dim);
  }

  .guide-submit {
    margin-top: 0.25rem;
    width: 100%;
    justify-content: center;
    font-size: 0.88rem;
  }

  .guide-trust {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    margin: 1.25rem -0.25rem 0;
  }

  .guide-trust-item {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-tertiary, rgba(255,255,255,0.3));
    margin: 0.25rem 0.5rem 0.25rem 0;
  }

  [data-theme="light"] .guide-trust-item {
    color: rgba(0,0,0,0.3);
  }

  .guide-trust-item:not(:last-child)::after {
    content: '·';
    margin-left: 0.5rem;
    opacity: 0.4;
  }

  .guide-success {
    display: none;
    text-align: center;
    padding: 2rem 1rem;
  }

  .guide-success-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
    color: var(--accent);
  }

  .guide-success h3 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .guide-success p {
    font-size: 0.92rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  .guide-error {
    display: none;
    font-size: 0.82rem;
    color: #f87171;
    margin-top: 0.25rem;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .guide-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .guide-form-col {
      padding: 2rem 1.5rem;
    }
  }
</style>

<div class="guide-page">
  <div class="guide-inner">

    <!-- LEFT: content -->
    <div class="guide-left">
      <div class="guide-label">Free from Psygaia</div>

      <h1 class="guide-heading">
        The Essential Guide to<br><span class="grad-text">Psychedelic Journeying</span>
      </h1>

      <p class="guide-body">
        An ecological and systems-based framework for intentional psychedelic exploration — from ancient Indigenous wisdom to modern neuroscience. Everything you need to know before, during, and after a journey.
      </p>

      <div class="guide-what-title">What's inside</div>
      <ul class="guide-what">
        <li>
          <span class="guide-what-dot"></span>
          <span><strong>The Psygaia Framework</strong> — an emerging theory of cognitive symbiosis, ecological attunement, and why psychedelics consistently produce a felt sense of connection with the living world</span>
        </li>
        <li>
          <span class="guide-what-dot"></span>
          <span><strong>Substance profiles</strong> — psilocybin, LSD, DMT, ketamine, San Pedro, Peyote, and more: their unique qualities, histories, and what to expect</span>
        </li>
        <li>
          <span class="guide-what-dot"></span>
          <span><strong>Preparation</strong> — assessing emotional readiness, setting intention, choosing your environment, and the details most people overlook</span>
        </li>
        <li>
          <span class="guide-what-dot"></span>
          <span><strong>Navigation</strong> — how to stay grounded during a journey, work with breathwork, release the need for control, and trust the process</span>
        </li>
        <li>
          <span class="guide-what-dot"></span>
          <span><strong>Integration</strong> — journaling, mindfulness, nature immersion, and community practices for carrying insights into everyday life</span>
        </li>
        <li>
          <span class="guide-what-dot"></span>
          <span><strong>Reciprocity and stewardship</strong> — why individual healing and planetary health are inseparable, and how to give back</span>
        </li>
      </ul>
    </div>

    <!-- RIGHT: form -->
    <div class="guide-form-col">
      <div class="guide-form-heading">Get the guide — free</div>
      <p class="guide-form-sub">Enter your name and email and we'll send it straight to your inbox.</p>

      <div id="guide-form-wrap">
        <form class="guide-form" id="guide-form" novalidate>
          <div class="guide-field">
            <label for="guide-name">First name</label>
            <input
              type="text"
              id="guide-name"
              name="first_name"
              placeholder="Your first name"
              autocomplete="given-name"
              required
            />
          </div>
          <div class="guide-field">
            <label for="guide-email">Email</label>
            <input
              type="email"
              id="guide-email"
              name="email"
              placeholder="your@email.com"
              autocomplete="email"
              required
            />
            <span class="guide-error" id="guide-error">Please enter a valid email address.</span>
          </div>
          <button type="submit" class="btn btn-primary guide-submit">
            Send me the guide →
          </button>
        </form>

        <div class="guide-success" id="guide-success">
          <div class="guide-success-icon">✦</div>
          <h3>You're in.</h3>
          <p>Check your inbox — the guide is on its way.<br>Welcome to the Psygaia community.</p>
        </div>

        <div class="guide-trust">
          <span class="guide-trust-item">Free</span>
          <span class="guide-trust-item">No spam</span>
          <span class="guide-trust-item">Unsubscribe anytime</span>
          <span class="guide-trust-item">Nonprofit</span>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- Support Banner -->
<div class="footer-support">
  <div class="footer-support-inner">
    <div class="footer-support-text">
      <p class="footer-support-label">Support Psychedelic Research &amp; Education</p>
      <p class="footer-support-headline">This work exists because people like you care.</p>
      <p class="footer-support-body">Psygaia is an independent nonprofit — no ads, no corporate sponsors. Just rigorous, freely available education in service of safer psychedelic practice and planetary health. Your support keeps this work alive.</p>
    </div>
    <a class="footer-support-btn" href="https://buy.stripe.com/bIYcMX3W893Z4o04gg" target="_blank" rel="noopener">Support This Work →</a>
  </div>
</div>

<script is:inline data-astro-rerun>
  (function () {
    var form = document.getElementById('guide-form');
    var success = document.getElementById('guide-success');
    var errorEl = document.getElementById('guide-error');

    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      errorEl.style.display = 'none';

      var name = document.getElementById('guide-name').value.trim();
      var email = document.getElementById('guide-email').value.trim();

      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        errorEl.style.display = 'block';
        return;
      }

      var btn = form.querySelector('button[type="submit"]');
      btn.textContent = 'Sending…';
      btn.disabled = true;

      try {
        var res = await fetch('/.netlify/functions/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email, first_name: name, source: 'htup-guide-page' }),
        });
        if (!res.ok) throw new Error('Subscribe failed');

        form.style.display = 'none';
        success.style.display = 'block';
      } catch (err) {
        btn.textContent = 'Send me the guide →';
        btn.disabled = false;
        errorEl.textContent = 'Something went wrong. Please try again.';
        errorEl.style.display = 'block';
      }
    });
  })();
</script>

</Base>
