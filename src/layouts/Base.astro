---
import { ClientRouter } from 'astro:transitions';
import Nav from '../components/Nav.astro';
import SearchOverlay from '../components/SearchOverlay.astro';
import MobileDrawer from '../components/MobileDrawer.astro';
import Footer from '../components/Footer.astro';
import EmailPopup from '../components/EmailPopup.astro';
import EmailModal from '../components/EmailModal.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogImage?: string;
  ogType?: string;
  hideProgress?: boolean;
  hideEmailPopup?: boolean;
}

const {
  title,
  description,
  canonicalPath = '/',
  ogImage = '/og-image.png',
  ogType = 'website',
  hideProgress = false,
  hideEmailPopup = false,
} = Astro.props;

const baseUrl = 'https://howtousepsychedelics.com';
const trailedPath = canonicalPath.endsWith('/') ? canonicalPath : canonicalPath + '/';
const canonicalUrl = `${baseUrl}${trailedPath}`;
const ogImageUrl = `${baseUrl}${ogImage}`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{title}</title>
  <meta name="description" content={description}/>
  <link rel="canonical" href={canonicalUrl}/>
  <meta property="og:site_name" content="How to Use Psychedelics"/>
  <meta property="og:type" content={ogType}/>
  <meta property="og:url" content={canonicalUrl}/>
  <meta property="og:title" content={title}/>
  <meta property="og:description" content={description}/>
  <meta property="og:image" content={ogImageUrl}/>
  <meta property="og:image:width" content="2048"/>
  <meta property="og:image:height" content="1072"/>
  <meta name="twitter:card" content="summary_large_image"/>
  <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)"/>
  <meta name="theme-color" content="#faf8f4" media="(prefers-color-scheme: light)"/>
  <link rel="icon" type="image/png" href="/favicon.png"/>
  <link rel="alternate" type="application/rss+xml" title="How to Use Psychedelics — Articles" href="/rss.xml"/>
  <link rel="preload" href="/fonts/dm-sans-latin.woff2" as="font" type="font/woff2" crossorigin/>
  <link rel="preload" href="/fonts/space-grotesk-latin.woff2" as="font" type="font/woff2" crossorigin/>

  <!-- Structured data: site-wide -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@graph': [
      {
        '@type': 'Organization',
        '@id': `${baseUrl}/#organization`,
        name: 'How to Use Psychedelics',
        url: `${baseUrl}/`,
        logo: `${baseUrl}/favicon-512.png`,
      },
      {
        '@type': 'WebSite',
        '@id': `${baseUrl}/#website`,
        name: 'How to Use Psychedelics',
        url: `${baseUrl}/`,
        publisher: { '@id': `${baseUrl}/#organization` },
      },
    ],
  })} />

  <!-- DataFast Analytics -->
  <script defer data-website-id="dfid_2Uvi8Ss7ZLqjk1dk1nbVz" data-domain="howtousepsychedelics.com" src="https://datafa.st/js/script.js"></script>

  <!-- Umami Analytics -->
  <script defer src="https://cloud.umami.is/script.js" data-website-id="73ef0fd9-4507-492e-bb89-fda45a409cce"></script>

  <!-- Theme detection before first paint -->
  <script is:inline>
    (function(){var t=localStorage.getItem('htup-theme');var theme=t?t:(window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light');document.documentElement.setAttribute('data-theme',theme);})()
  </script>

  <!-- Netlify Identity (for Decap CMS) — only loaded when an identity token lands on the site -->
  <script is:inline>
    (function() {
      if (!/(invite_token|recovery_token|confirmation_token|email_change_token|access_token)=/.test(window.location.hash)) return;
      var s = document.createElement('script');
      s.src = 'https://identity.netlify.com/v1/netlify-identity-widget.js';
      s.onload = function() {
        window.netlifyIdentity.on('init', function(user) {
          if (!user) {
            window.netlifyIdentity.on('login', function() {
              document.location.href = '/admin/';
            });
          }
        });
      };
      document.head.appendChild(s);
    })();
  </script>

  <ClientRouter />

  <slot name="head" />
</head>
<body>

  <!-- Skip link for keyboard users -->
  <a class="skip-link" href="#main-content">Skip to content</a>

  <!-- Scroll Progress -->
  {!hideProgress && <div class="scroll-progress" id="scrollProgress"></div>}

  <!-- Nav -->
  <div transition:persist="chrome-nav"><Nav /></div>

  <!-- Search Overlay -->
  <div transition:persist="chrome-search"><SearchOverlay /></div>

  <!-- Mobile Drawer -->
  <div transition:persist="chrome-drawer"><MobileDrawer /></div>

  <!-- Page Content -->
  <main id="main-content" data-hide-cta={hideEmailPopup ? 'true' : undefined}>
    <slot />
  </main>

  <!-- Mobile TOC FAB -->
  <div transition:persist="chrome-toc">
  <button class="toc-fab" id="tocFab" aria-label="Table of contents">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="15" y2="12"/><line x1="3" y1="18" x2="18" y2="18"/></svg>
  </button>

  <!-- Mobile TOC Modal -->
  <div class="toc-modal" id="tocModal">
    <div class="toc-modal-inner">
      <div class="toc-modal-header">
        <span class="toc-modal-title">Contents</span>
        <button class="toc-modal-close" id="tocModalClose" aria-label="Close">&times;</button>
      </div>
      <ul class="toc-modal-list" id="tocModalList"></ul>
    </div>
  </div>
  </div>

  <!-- Email Signup Popup -->
  {!hideEmailPopup && <div transition:persist="chrome-popup"><EmailPopup /></div>}

  <!-- Email Signup Modal (triggered by Get the Guide buttons) -->
  <div transition:persist="chrome-modal"><EmailModal /></div>

  <!-- Footer -->
  <Footer />

  <!-- Disclaimer -->
  <div class="disclaimer">
    <p>This site provides harm reduction education only. Psychedelics are controlled substances in most jurisdictions.<br>Nothing here constitutes medical or legal advice. In crisis, see our <a href="/crisis/">crisis resources</a> or contact a healthcare provider immediately.</p>
  </div>

  <!-- Shared Scripts -->
  <script is:inline>
    (function () {
      // Chrome bindings run exactly once — the nav, search, drawer,
      // popups and FAB persist across view transitions.
      if (window.__htupChrome) return;
      window.__htupChrome = true;

      // ── Theme ──
      document.querySelector('.theme-toggle').addEventListener('click', function () {
        var html = document.documentElement;
        html.classList.add('theme-switching');
        if (html.getAttribute('data-theme') === 'light') {
          html.removeAttribute('data-theme');
          localStorage.setItem('htup-theme', 'dark');
        } else {
          html.setAttribute('data-theme', 'light');
          localStorage.setItem('htup-theme', 'light');
        }
        setTimeout(function () { html.classList.remove('theme-switching'); }, 350);
      });

      // View transitions replace <html> attributes — re-apply theme before paint
      document.addEventListener('astro:after-swap', function () {
        var t = localStorage.getItem('htup-theme');
        var theme = t ? t : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        if (theme === 'light') document.documentElement.setAttribute('data-theme', 'light');
        else document.documentElement.removeAttribute('data-theme');
      });

      // ── Search (command palette) ──
      var searchIndex = null;
      var searchDebounce = null;
      var paletteSel = 0;

      var QUICK_LINKS = [
        { title: 'All Substances', url: '/substances/' },
        { title: 'Journey Planner', url: '/planner/' },
        { title: 'Microdosing', url: '/microdosing/' },
        { title: 'Research Library', url: '/research/' },
        { title: 'Glossary', url: '/glossary/' },
        { title: 'Facilitation', url: '/facilitation/' },
        { title: 'Crisis Resources', url: '/crisis/' },
      ];

      function loadSearchIndex() {
        if (searchIndex) return Promise.resolve(searchIndex);
        return fetch('/search-index.json')
          .then(function (r) { return r.json(); })
          .then(function (data) { searchIndex = data; return data; });
      }

      function escapeRe(s) {
        return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      }

      // Every term must hit somewhere; terms sum their scores, and the
      // whole phrase appearing in the title earns a bonus.
      function scoreResult(entry, terms, phrase) {
        var title = (entry.section || entry.page).toLowerCase();
        var page = entry.page.toLowerCase();
        var text = entry.text.toLowerCase();
        var total = 0;
        for (var i = 0; i < terms.length; i++) {
          var t = terms[i];
          var s = 0;
          if (title === t) s += 100;
          else if (title.startsWith(t)) s += 60;
          else if (title.includes(t)) s += 40;
          if (!entry.section && page.includes(t)) s += 20;
          if (text.includes(t)) s += 10;
          var wordBoundary = new RegExp('\\b' + escapeRe(t));
          if (wordBoundary.test(title)) s += 15;
          if (wordBoundary.test(text)) s += 5;
          if (s === 0) return 0;
          total += s;
        }
        if (terms.length > 1 && title.includes(phrase)) total += 30;
        return total;
      }

      function getSnippet(text, terms) {
        var lower = text.toLowerCase();
        var pos = -1;
        for (var i = 0; i < terms.length; i++) {
          var p = lower.indexOf(terms[i]);
          if (p !== -1 && (pos === -1 || p < pos)) pos = p;
        }
        var snippet;
        if (pos === -1) snippet = text.slice(0, 120) + (text.length > 120 ? '…' : '');
        else {
          var start = Math.max(0, pos - 50);
          var end = Math.min(text.length, pos + 120);
          snippet = (start > 0 ? '…' : '') + text.slice(start, end) + (end < text.length ? '…' : '');
        }
        // Longest terms first so "setting" wins over "set" in the alternation
        var escaped = terms.slice().sort(function (a, b) { return b.length - a.length; }).map(escapeRe).join('|');
        return snippet.replace(new RegExp('(' + escaped + ')', 'gi'), '<mark>$1</mark>');
      }

      function paletteRows() {
        return document.getElementById('searchResults').querySelectorAll('.search-result');
      }

      function setPaletteSel(idx, scroll) {
        var rows = paletteRows();
        if (!rows.length) return;
        paletteSel = Math.max(0, Math.min(idx, rows.length - 1));
        for (var i = 0; i < rows.length; i++) {
          rows[i].classList.toggle('selected', i === paletteSel);
        }
        if (scroll) rows[paletteSel].scrollIntoView({ block: 'nearest' });
      }

      function renderQuickLinks() {
        var container = document.getElementById('searchResults');
        container.innerHTML = '<div class="palette-group-label">Quick links</div>'
          + QUICK_LINKS.map(function (l) {
            return '<a class="search-result search-result-quick" href="' + l.url + '">'
              + '<div class="search-result-title">' + l.title + '</div></a>';
          }).join('');
        setPaletteSel(0, false);
      }

      function runSearch(q) {
        var container = document.getElementById('searchResults');
        if (!q) { renderQuickLinks(); return; }
        if (!searchIndex) { container.innerHTML = '<div class="search-hint">Loading…</div>'; return; }
        var terms = q.split(/\s+/);
        // Stopwords score everywhere and litter the highlights — drop
        // them, but never below one real term
        var STOP = /^(a|an|and|are|do|for|how|i|in|is|it|my|of|on|or|the|to|vs|what|with)$/;
        var filtered = terms.filter(function (t) { return !STOP.test(t); });
        if (filtered.length) terms = filtered;
        var scored = [];
        for (var i = 0; i < searchIndex.length; i++) {
          var entry = searchIndex[i];
          var sc = scoreResult(entry, terms, q);
          if (sc > 0) scored.push({ entry: entry, score: sc });
        }
        scored.sort(function (a, b) { return b.score - a.score; });
        var seen = {};
        var results = [];
        for (var j = 0; j < scored.length && results.length < 12; j++) {
          var e = scored[j].entry;
          var key = e.url + e.hash;
          if (seen[key]) continue;
          seen[key] = true;
          results.push(e);
        }
        if (!results.length) { container.innerHTML = '<div class="search-no-results">No results for “' + q.replace(/</g, '&lt;') + '”</div>'; return; }
        // Group by type; groups keep best-score order via first appearance
        var groups = [];
        var byType = {};
        for (var k = 0; k < results.length; k++) {
          var r = results[k];
          var type = r.type || 'Guides';
          if (!byType[type]) { byType[type] = []; groups.push(type); }
          byType[type].push(r);
        }
        container.innerHTML = groups.map(function (type) {
          return '<div class="palette-group-label">' + type + '</div>'
            + byType[type].map(function (r) {
              var title = r.section ? r.section : r.page;
              var breadcrumb = r.section ? '<div class="search-result-page">' + r.page + '</div>' : '';
              var snippet = getSnippet(r.text, terms);
              return '<a class="search-result" href="' + r.url + r.hash + '">'
                + breadcrumb
                + '<div class="search-result-title">' + title + '</div>'
                + '<div class="search-result-desc">' + snippet + '</div></a>';
            }).join('');
        }).join('');
        setPaletteSel(0, false);
      }

      function openSearch() {
        loadSearchIndex().then(function () {
          var q = document.getElementById('searchInput').value.toLowerCase().trim();
          if (q) runSearch(q);
        });
        renderQuickLinks();
        document.getElementById('searchOverlay').classList.add('open');
        setTimeout(function () { document.getElementById('searchInput').focus(); }, 100);
        document.body.style.overflow = 'hidden';
      }

      function closeSearch() {
        document.getElementById('searchOverlay').classList.remove('open');
        document.getElementById('searchInput').value = '';
        document.body.style.overflow = '';
      }

      document.getElementById('searchOverlay').addEventListener('click', function (e) {
        if (e.target === this) closeSearch();
      });
      // Search results are links — close the overlay when one is chosen
      document.getElementById('searchResults').addEventListener('click', function (e) {
        if (e.target.closest('a')) closeSearch();
      });
      // Hover follows the mouse, but only on real movement — keyboard
      // scrolling must not yank the selection back under the cursor
      document.getElementById('searchResults').addEventListener('mousemove', function (e) {
        var row = e.target.closest('.search-result');
        if (!row) return;
        var rows = paletteRows();
        for (var i = 0; i < rows.length; i++) {
          if (rows[i] === row) { if (i !== paletteSel) setPaletteSel(i, false); return; }
        }
      });
      document.getElementById('searchCloseBtn').addEventListener('click', closeSearch);
      document.querySelector('.search-open-btn').addEventListener('click', openSearch);
      if (!/Mac|iP(hone|ad|od)/.test(navigator.platform || '')) {
        document.querySelector('.nav-kbd').textContent = 'Ctrl K';
      }
      document.getElementById('searchInput').addEventListener('input', function (e) {
        var q = e.target.value.toLowerCase().trim();
        clearTimeout(searchDebounce);
        searchDebounce = setTimeout(function () {
          if (!searchIndex) loadSearchIndex().then(function () { runSearch(q); });
          else runSearch(q);
        }, 80);
      });

      // ── Mobile drawer ──
      function closeDrawer() {
        document.getElementById('mobileDrawer').classList.remove('open');
        document.getElementById('drawerBackdrop').classList.remove('open');
        document.querySelector('.nav-hamburger').classList.remove('open');
        document.body.style.overflow = '';
      }

      document.querySelector('.nav-hamburger').addEventListener('click', function () {
        var drawer = document.getElementById('mobileDrawer');
        if (drawer.classList.contains('open')) { closeDrawer(); return; }
        drawer.classList.add('open');
        document.getElementById('drawerBackdrop').classList.add('open');
        document.querySelector('.nav-hamburger').classList.add('open');
        document.body.style.overflow = 'hidden';
      });
      document.getElementById('drawerBackdrop').addEventListener('click', closeDrawer);
      document.getElementById('drawerCloseBtn').addEventListener('click', closeDrawer);
      document.querySelectorAll('.drawer-section-btn').forEach(function (btn) {
        btn.addEventListener('click', function () { this.parentElement.classList.toggle('expanded'); });
      });
      document.querySelectorAll('.mobile-drawer .drawer-section-links a, .mobile-drawer .drawer-link, .mobile-drawer .drawer-cta').forEach(function (link) {
        link.addEventListener('click', closeDrawer);
      });

      document.addEventListener('keydown', function (e) {
        if (document.getElementById('searchOverlay').classList.contains('open')) {
          if (e.key === 'ArrowDown') { e.preventDefault(); setPaletteSel(paletteSel + 1, true); return; }
          if (e.key === 'ArrowUp') { e.preventDefault(); setPaletteSel(paletteSel - 1, true); return; }
          if (e.key === 'Enter') {
            var rows = paletteRows();
            if (rows.length) { e.preventDefault(); rows[paletteSel].click(); }
            return;
          }
        }
        if (e.key === 'Escape') { closeSearch(); closeDrawer(); }
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); openSearch(); }
      });

      function getNavHeight() {
        var nav = document.querySelector('nav');
        return nav ? nav.offsetHeight : 72;
      }

      // Fixed chrome above anchored content: nav + (on substance pages)
      // the sticky HUD strip, which is in the layout even while hidden
      function getScrollOffset() {
        var off = getNavHeight() + 12;
        var strip = document.querySelector('[data-hud-sticky]');
        if (strip) off += strip.offsetHeight;
        return off;
      }

      // ── Hash landing fix ──
      // The ClientRouter forces scrollRestoration to "manual" and its
      // fragment re-navigation is skipped by Chrome, so cross-page and
      // direct-load hash URLs land pinned to the top. Scroll ourselves,
      // but only when still at the top — a restored scroll position
      // (back/forward) must win.
      document.addEventListener('astro:page-load', function () {
        if (!location.hash || window.scrollY > 0) return;
        var id = decodeURIComponent(location.hash.slice(1));

        function jumpTo() {
          var target = document.getElementById(id);
          if (!target) return 0;
          var top = Math.max(0, target.getBoundingClientRect().top + window.scrollY - getScrollOffset());
          if (top > 1) window.scrollTo({ top: top, behavior: 'instant' });
          return top;
        }

        var expected = jumpTo();
        if (expected <= 1) return;
        // Image loads and per-page init shift layout after this event —
        // correct once more if the target drifted and the user hasn't
        // scrolled themselves. (Timeout, not rAF: must also run in
        // background tabs.)
        setTimeout(function () {
          if (Math.abs(window.scrollY - expected) < 2) jumpTo();
        }, 350);
      });

      // ── Sidebar TOC click (delegated — survives page swaps) ──
      document.addEventListener('click', function (e) {
        var a = e.target.closest('.sidebar-nav a');
        if (!a) return;
        e.preventDefault();
        var id = a.getAttribute('href').replace(/^.*#/, '');
        var target = document.getElementById(id);
        if (!target) return;
        var top = target.getBoundingClientRect().top + window.scrollY - getScrollOffset();
        var sidebar = a.closest('.sidebar-nav');
        if (sidebar) {
          sidebar.querySelectorAll('a').forEach(function (l) { l.classList.remove('active'); });
          a.classList.add('active');
        }
        window.scrollTo({ top: top, behavior: 'smooth' });
      });

      // ── Scroll spy + progress + FAB visibility (one live-querying listener) ──
      var spyTargets = [];
      var spyLinkMap = {};
      var rafPending = false;

      function runSpy() {
        rafPending = false;
        document.querySelector('nav').classList.toggle('scrolled', window.scrollY > 24);
        var progressBar = document.getElementById('scrollProgress');
        if (progressBar) {
          var docHeight = document.documentElement.scrollHeight - window.innerHeight;
          progressBar.style.width = (docHeight > 0 ? (window.scrollY / docHeight) * 100 : 0) + '%';
        }
        var fab = document.getElementById('tocFab');
        if (fab && window.innerWidth <= 900) {
          fab.classList.toggle('visible', window.scrollY > 200 && !fab.hasAttribute('data-off'));
        }
        if (!spyTargets.length) return;
        var trigger = getNavHeight() + 20;
        var activeId = null;
        for (var i = 0; i < spyTargets.length; i++) {
          if (spyTargets[i].el.getBoundingClientRect().top <= trigger) activeId = spyTargets[i].id;
          else break;
        }
        if (!activeId && spyTargets.length) activeId = spyTargets[0].id;
        Object.keys(spyLinkMap).forEach(function (k) { spyLinkMap[k].classList.remove('active'); });
        if (spyLinkMap[activeId]) spyLinkMap[activeId].classList.add('active');
      }

      window.addEventListener('scroll', function () {
        if (rafPending) return;
        rafPending = true;
        requestAnimationFrame(runSpy);
      }, { passive: true });

      function initScrollSpy() {
        spyTargets = [];
        spyLinkMap = {};
        var sidebar = document.querySelector('.sidebar-nav');
        // Pages without a TOC still need the nav scrolled-state refresh
        if (!sidebar) { runSpy(); return; }
        sidebar.querySelectorAll('a[href]').forEach(function (a) {
          var hash = a.getAttribute('href').replace(/^.*#/, '');
          if (hash) spyLinkMap[hash] = a;
        });
        Object.keys(spyLinkMap).forEach(function (id) {
          var el = document.getElementById(id);
          if (el) spyTargets.push({ el: el, id: id });
        });
        spyTargets.sort(function (a, b) {
          return (a.el.getBoundingClientRect().top) - (b.el.getBoundingClientRect().top);
        });
        runSpy();
      }

      // ── Mobile TOC modal (persisted chrome; reads current sidebar) ──
      var tocModal = document.getElementById('tocModal');
      var tocFab = document.getElementById('tocFab');

      function closeTocModal() {
        tocModal.classList.remove('open');
        document.body.style.overflow = '';
      }

      tocFab.addEventListener('click', function () {
        var sidebarNav = document.querySelector('.sidebar-nav');
        if (!sidebarNav) return;
        var modalList = document.getElementById('tocModalList');
        modalList.innerHTML = '';
        sidebarNav.querySelectorAll('a').forEach(function (a) {
          var li = document.createElement('li');
          var link = document.createElement('a');
          link.href = a.getAttribute('href');
          link.textContent = a.textContent.trim();
          if (a.classList.contains('active')) link.classList.add('active');
          link.addEventListener('click', function (e) {
            e.preventDefault();
            closeTocModal();
            var id = this.getAttribute('href').replace(/^.*#/, '');
            var target = document.getElementById(id);
            if (target) {
              var top = target.getBoundingClientRect().top + window.scrollY - getScrollOffset();
              setTimeout(function () { window.scrollTo({ top: top, behavior: 'smooth' }); }, 50);
            }
          });
          li.appendChild(link);
          modalList.appendChild(li);
        });
        tocModal.classList.add('open');
        document.body.style.overflow = 'hidden';
      });

      document.getElementById('tocModalClose').addEventListener('click', closeTocModal);
      tocModal.addEventListener('click', function (e) { if (e.target === tocModal) closeTocModal(); });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && tocModal.classList.contains('open')) closeTocModal();
      });

      // ── FAQ accordion (delegated) ──
      function syncFaqAria(item) {
        var q = item.querySelector('.faq-question, .faq-q');
        if (q) q.setAttribute('aria-expanded', item.classList.contains('open') ? 'true' : 'false');
      }

      function toggleFaq(question) {
        var item = question.closest('.faq-item');
        if (!item) return;
        var parent = item.parentElement;
        if (parent) {
          parent.querySelectorAll('.faq-item.open').forEach(function (faq) {
            if (faq !== item) {
              faq.classList.remove('open');
              syncFaqAria(faq);
              var tog = faq.querySelector('.tog, .faq-icon');
              if (tog && tog.tagName !== 'svg') tog.textContent = '+';
            }
          });
        }
        item.classList.toggle('open');
        syncFaqAria(item);
        var tog = question.querySelector('.tog, .faq-icon');
        if (tog && tog.tagName !== 'svg') tog.textContent = item.classList.contains('open') ? '−' : '+';
      }

      document.addEventListener('click', function (e) {
        var question = e.target.closest('.faq-question, .faq-q');
        if (question) toggleFaq(question);
      });
      document.addEventListener('keydown', function (e) {
        if (e.key !== 'Enter' && e.key !== ' ') return;
        var question = e.target.closest && e.target.closest('.faq-question, .faq-q');
        if (!question) return;
        e.preventDefault();
        toggleFaq(question);
      });

      // ── Glossary tooltip card (persisted; content set per link) ──
      var glossTip = null;
      var glossHideTimer = null;

      function ensureGlossTip() {
        if (glossTip && document.body.contains(glossTip)) return glossTip;
        glossTip = document.createElement('div');
        glossTip.className = 'gloss-tip';
        glossTip.setAttribute('role', 'tooltip');
        glossTip.innerHTML = '<div class="gloss-tip-name"></div><div class="gloss-tip-def"></div><a class="gloss-tip-more" href="#">Full definition →</a>';
        glossTip.addEventListener('mouseenter', function () { clearTimeout(glossHideTimer); });
        glossTip.addEventListener('mouseleave', scheduleGlossHide);
        document.body.appendChild(glossTip);
        return glossTip;
      }

      function showGloss(ref) {
        var tip = ensureGlossTip();
        clearTimeout(glossHideTimer);
        tip.querySelector('.gloss-tip-name').textContent = ref.getAttribute('data-gloss-name');
        tip.querySelector('.gloss-tip-def').textContent = ref.getAttribute('data-gloss-def');
        tip.querySelector('.gloss-tip-more').href = ref.href;
        tip.classList.add('visible');
        var r = ref.getBoundingClientRect();
        var tw = tip.offsetWidth;
        var th = tip.offsetHeight;
        var left = Math.max(12, Math.min(r.left + r.width / 2 - tw / 2, window.innerWidth - tw - 12));
        var top = r.top - th - 10;
        if (top < 12) top = r.bottom + 10;
        tip.style.left = left + window.scrollX + 'px';
        tip.style.top = top + window.scrollY + 'px';
      }

      function hideGlossNow() { if (glossTip) glossTip.classList.remove('visible'); }
      function scheduleGlossHide() {
        clearTimeout(glossHideTimer);
        glossHideTimer = setTimeout(hideGlossNow, 200);
      }

      document.addEventListener('mouseover', function (e) {
        var ref = e.target.closest && e.target.closest('.gloss-ref');
        if (ref) showGloss(ref);
      });
      document.addEventListener('mouseout', function (e) {
        var ref = e.target.closest && e.target.closest('.gloss-ref');
        if (ref) scheduleGlossHide();
      });
      document.addEventListener('focusin', function (e) {
        var ref = e.target.closest && e.target.closest('.gloss-ref');
        if (ref) showGloss(ref);
      });
      document.addEventListener('focusout', function (e) {
        var ref = e.target.closest && e.target.closest('.gloss-ref');
        if (ref) scheduleGlossHide();
      });
      window.addEventListener('scroll', hideGlossNow, { passive: true });

      // ══════════════════════════════════════════════
      // PER-PAGE INIT — runs on first load and after
      // every view-transition navigation
      // ══════════════════════════════════════════════
      var SKIP_CLOSEST = 'a, h1, h2, h3, h4, h5, h6, strong, b, button, code, pre, .callout-label, .content-hero-subtitle, .email-cta-box, .blog-related, .related-strip, .faq-question, .faq-q';

      function linkGlossaryTerms() {
        var body = document.querySelector('.article-body');
        if (!body) return;
        if (window.location.pathname.indexOf('/glossary') === 0) return;
        if (body.querySelector('.gloss-ref')) return;

        var load = window.__glossData || (window.__glossData = fetch('/glossary-data.json').then(function (r) { return r.json(); }));
        load.then(function (terms) {
          if (!document.body.contains(body) || body.querySelector('.gloss-ref')) return;
          var entries = [];
          terms.forEach(function (t) {
            t.names.forEach(function (n) {
              if (n.length < 4) return;
              entries.push({ id: t.id, name: t.name, match: n, def: t.def });
            });
          });
          entries.sort(function (a, b) { return b.match.length - a.match.length; });
          var linkedIds = {};

          function collectTextNodes() {
            var walker = document.createTreeWalker(body, NodeFilter.SHOW_TEXT, {
              acceptNode: function (node) {
                if (!node.nodeValue || node.nodeValue.length < 4) return NodeFilter.FILTER_REJECT;
                if (node.parentElement && node.parentElement.closest(SKIP_CLOSEST)) return NodeFilter.FILTER_REJECT;
                return NodeFilter.FILTER_ACCEPT;
              }
            });
            var nodes = [];
            while (walker.nextNode()) nodes.push(walker.currentNode);
            return nodes;
          }

          entries.forEach(function (entry) {
            if (linkedIds[entry.id]) return;
            var escaped = entry.match.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
            var re = new RegExp('\\b(' + escaped + 's?)\\b', 'i');
            var nodes = collectTextNodes();
            for (var i = 0; i < nodes.length; i++) {
              var node = nodes[i];
              var m = re.exec(node.nodeValue);
              if (!m) continue;
              var link = document.createElement('a');
              link.className = 'gloss-ref';
              link.href = '/glossary/#' + entry.id;
              link.setAttribute('data-gloss-name', entry.name);
              link.setAttribute('data-gloss-def', entry.def);
              link.textContent = m[1];
              var after = node.splitText(m.index);
              after.nodeValue = after.nodeValue.slice(m[1].length);
              node.parentNode.insertBefore(link, after);
              linkedIds[entry.id] = true;
              break;
            }
          });
        }).catch(function () { /* degrade silently */ });
      }

      function initPageContent() {
        // Scroll reveal
        var revealObserver = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              revealObserver.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1 });
        document.querySelectorAll('.reveal').forEach(function (el) { revealObserver.observe(el); });

        // FAB availability for this page
        var fab = document.getElementById('tocFab');
        if (fab) {
          if (document.querySelector('.sidebar-nav')) fab.removeAttribute('data-off');
          else { fab.setAttribute('data-off', ''); fab.classList.remove('visible'); }
        }

        initScrollSpy();
        hideGlossNow();

        // FAQ aria pass
        document.querySelectorAll('.faq-question, .faq-q').forEach(function (q) {
          q.setAttribute('role', 'button');
          q.setAttribute('tabindex', '0');
          var item = q.closest('.faq-item');
          q.setAttribute('aria-expanded', item && item.classList.contains('open') ? 'true' : 'false');
        });

        // Auto-inject "Get the Guide" CTA cards
        (function () {
          if (document.querySelector('main[data-hide-cta]')) return;
          var body = document.querySelector('.article-body');
          if (!body || body.querySelector('.email-cta-box')) return;
          var h2s = body.querySelectorAll('h2');
          if (!h2s.length) return;
          var positions = [];
          var count = h2s.length;
          if (count >= 9) positions = [Math.floor(count * 0.25), Math.floor(count * 0.5), Math.floor(count * 0.75)];
          else if (count >= 4) positions = [Math.floor(count * 0.33), Math.floor(count * 0.66)];
          else positions = [Math.min(1, count - 1)];
          var html = '<div class="email-cta-box">'
            + '<div class="email-cta-box-label">Free Resource</div>'
            + '<div class="email-cta-box-title">Get the complete psychedelics guide — free.</div>'
            + '<div class="email-cta-box-desc">Research and mindfulness-based frameworks for preparation, safety, and integration. Used by thousands of readers — delivered to your inbox, no cost.</div>'
            + '<a class="email-cta-btn" href="#get-the-guide">Get the Guide →</a>'
            + '</div>';
          for (var i = positions.length - 1; i >= 0; i--) {
            var target = h2s[positions[i]];
            if (target && target.closest('.content-section')) target.closest('.content-section').insertAdjacentHTML('beforebegin', html);
            else if (target) target.insertAdjacentHTML('beforebegin', html);
          }
        })();

        linkGlossaryTerms();
      }

      document.addEventListener('astro:page-load', initPageContent);
    })();
  </script>

</body>
</html>
