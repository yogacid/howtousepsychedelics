<script is:inline>
  // Week curriculum tabs
  function showWeek(n, btn) {
    document.querySelectorAll('.week-panel').forEach(function(p) { p.classList.remove('active'); });
    document.querySelectorAll('.week-tab').forEach(function(t) { t.classList.remove('active'); });
    document.getElementById('week' + n).classList.add('active');
    btn.classList.add('active');
  }

  // Sticky CTA — shows after hero scrolls out of view
  (function() {
    var stickyCta = document.getElementById('stickyCta');
    var hero = document.querySelector('.hero');
    if (!stickyCta || !hero) return;
    var heroObserver = new IntersectionObserver(function(entries) {
      stickyCta.classList.toggle('visible', !entries[0].isIntersecting);
    }, { threshold: 0.1 });
    heroObserver.observe(hero);

    // iOS Safari: adjust bottom for keyboard/viewport changes
    if (window.visualViewport) {
      var wrap = document.getElementById('stickyCtaWrap');
      function updateCtaBottom() {
        var offset = window.innerHeight - window.visualViewport.height - window.visualViewport.offsetTop;
        wrap.style.bottom = Math.max(0, offset) + 'px';
      }
      window.visualViewport.addEventListener('resize', updateCtaBottom);
    }
  })();
</script>

