      '5-MeO-DMT+Ibogaine': {r:'Dangerous', n:'Both have complex pharmacology. Combined cardiac and serotonergic risk.'},
      'Ibogaine+MDMA': {r:'Dangerous', n:'Combined cardiac and serotonergic risk. Do not combine.'},
      'Ibogaine+Ketamine': {r:'Caution', n:'Both affect cardiac function. Limited data.'},
      'Cannabis+Ibogaine': {r:'Caution', n:'Cannabis increases heart rate. Ibogaine affects cardiac conduction.'},
      'Alcohol+Ibogaine': {r:'Unsafe', n:'Combined CNS depression and cardiac risk.'}
    };

    function getKey(a, b) { return [a, b].sort().join('+'); }

    function getInteraction(a, b) {
      if (a === b) return {r:'\u2014', n:'Same substance.'};
      var key = getKey(a, b);
      return data[key] || {r:'Low Risk', n:'No specific interaction data available for this pair. This does not mean the combination is safe. Research independently and exercise caution.'};
    }

    var ratingStyles = {
      'Low Risk & Synergy': {bg:'rgba(62,201,191,0.13)', border:'rgba(62,201,191,0.45)', color:'#3ec9bf', sym:'\u2191'},
      'Low Risk': {bg:'rgba(62,201,191,0.07)', border:'rgba(62,201,191,0.25)', color:'#3ec9bf', sym:'\u25CB'},
      'Low Risk & Decrease': {bg:'rgba(92,184,74,0.12)', border:'rgba(92,184,74,0.40)', color:'#5cb84a', sym:'\u2193'},
      'Caution': {bg:'rgba(212,180,50,0.12)', border:'rgba(212,180,50,0.40)', color:'#d4b432', sym:'\u25B3'},
      'Unsafe': {bg:'rgba(212,131,74,0.14)', border:'rgba(212,131,74,0.45)', color:'#d4836a', sym:'\u2715'},
      'Dangerous': {bg:'rgba(200,60,60,0.14)', border:'rgba(200,60,60,0.50)', color:'#d45252', sym:'\u2715'},
      '\u2014': {bg:'rgba(255,255,255,0.03)', border:'rgba(255,255,255,0.08)', color:'#787878', sym:'\u2014'}
    };

    var selA = document.getElementById('chk-a');
    var selB = document.getElementById('chk-b');
    substances.forEach(function(s) {
      selA.innerHTML += '<option value="' + s + '">' + s + '</option>';
      selB.innerHTML += '<option value="' + s + '">' + s + '</option>';
    });

    function updateResult() {
      var a = selA.value, b = selB.value;
      var el = document.getElementById('chk-result');
      var empty = document.getElementById('chk-empty');
      if (!a || !b) { el.style.display = 'none'; empty.style.display = 'flex'; return; }
      var info = getInteraction(a, b);
      var s = ratingStyles[info.r] || ratingStyles['Low Risk'];
      document.getElementById('chk-rating').textContent = info.r;
      document.getElementById('chk-rating').style.cssText = 'background:' + s.bg + ';border:1px solid ' + s.border + ';color:' + s.color;
      document.getElementById('chk-pair').textContent = a + ' + ' + b;
      document.getElementById('chk-note').textContent = info.n;
      el.style.display = 'block';
      empty.style.display = 'none';
    }

    selA.addEventListener('change', updateResult);
    selB.addEventListener('change', updateResult);

    // Build grid
    var grid = document.getElementById('chk-grid');
    var h = '<tr><th></th>';
    substances.forEach(function(s) {
      h += '<th><span>' + s + '</span></th>';
    });
    h += '</tr>';
    var rows = '';
    substances.forEach(function(rs) {
      var r = '<tr><td class="ic-row-label">' + rs + '</td>';
      substances.forEach(function(cs) {
        var info = getInteraction(rs, cs);
        var st = ratingStyles[info.r] || ratingStyles['Low Risk'];
        r += '<td style="background:' + st.bg + ';border-color:' + st.border + ';color:' + st.color + '" data-row="' + rs + '" data-col="' + cs + '">' + st.sym + '</td>';
      });
      r += '</tr>';
      rows += r;
    });
    grid.innerHTML = h + rows;

    // Tooltip system
    var tip = document.getElementById('ic-tooltip');
    var tipPair = document.getElementById('ic-tip-pair');
    var tipBadge = document.getElementById('ic-tip-badge');
    var tipNote = document.getElementById('ic-tip-note');

    grid.addEventListener('mouseover', function(e) {
      var cell = e.target.closest('td[data-row]');
      if (!cell) return;
      var rs = cell.getAttribute('data-row');
      var cs = cell.getAttribute('data-col');
      var info = getInteraction(rs, cs);
      var st = ratingStyles[info.r] || ratingStyles['Low Risk'];
      tipPair.textContent = rs + ' + ' + cs;
      tipBadge.textContent = info.r;
      tipBadge.style.cssText = 'background:' + st.bg + ';border-color:' + st.border + ';color:' + st.color;
      tipNote.textContent = info.n;
      tip.classList.add('is-visible');
    });

    grid.addEventListener('mousemove', function(e) {
      if (!tip.classList.contains('is-visible')) return;
      var x = e.clientX + 16;
      var y = e.clientY + 16;
      // Keep tooltip on screen
      var tw = tip.offsetWidth;
      var th = tip.offsetHeight;
      if (x + tw > window.innerWidth - 12) x = e.clientX - tw - 12;
      if (y + th > window.innerHeight - 12) y = e.clientY - th - 12;
      tip.style.left = x + 'px';
      tip.style.top = y + 'px';
    });

    grid.addEventListener('mouseout', function(e) {
      var cell = e.target.closest('td[data-row]');
      if (!cell) return;
      var related = e.relatedTarget;
      if (related && related.closest && related.closest('td[data-row]')) return;
      tip.classList.remove('is-visible');
    });

    // Tap support for mobile
    grid.addEventListener('click', function(e) {
      var cell = e.target.closest('td[data-row]');
      if (!cell) return;
      var rs = cell.getAttribute('data-row');
      var cs = cell.getAttribute('data-col');
      // Populate the quick lookup selects
      selA.value = rs;
      selB.value = cs;
      updateResult();
      // Scroll to result
      document.getElementById('ic-lookup-card').scrollIntoView({behavior:'smooth', block:'start'});
    });
  })();
  </script>

</BaseLayout>
