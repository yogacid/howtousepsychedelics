---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categories = ['All', 'Preparation', 'Safety', 'Microdosing', 'Integration', 'Science', 'Navigation', 'Community'];

const featured = allPosts.find(p => p.data.featured) || allPosts[0];
const posts = allPosts.filter(p => p !== featured);

function readTime(body: string) {
  const words = body.trim().split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 250));
}

function formatDate(date: Date) {
  return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<BaseLayout
  title="Blog — How to Use Psychedelics"
  description="Practical guides, harm reduction insights, and grounded perspectives on psychedelic preparation, safety, and integration."
  canonicalPath="/blog"
  hideProgress={true}
>

  <div class="content-page">

    <!-- Hero -->
    <div class="content-hero">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span class="breadcrumb-sep">/</span>
        <span>Blog</span>
      </div>
      <h1 class="content-hero-title">Blog</h1>
      <p class="content-hero-subtitle">Practical guides, harm reduction insights, and grounded perspectives on working with psychedelics safely and intentionally.</p>
    </div>

    <!-- Blog Content -->
    <div class="blog-listing">

      <!-- Featured Post -->
      {featured && (
        <a class="blog-featured" href={`/blog/${featured.id}/`}>
          <span class="blog-card-category">{featured.data.category}</span>
          <h2 class="blog-featured-title">{featured.data.title}</h2>
          <p class="blog-featured-desc">{featured.data.description}</p>
          <div class="blog-card-meta">
            <time datetime={featured.data.date.toISOString().slice(0, 10)}>{formatDate(featured.data.date)}</time>
            <span class="blog-meta-sep">&middot;</span>
            <span>{readTime(featured.body ?? '')} min read</span>
          </div>
          <span class="blog-featured-link">Read more &rarr;</span>
        </a>
      )}

      <!-- Category Pills -->
      <div class="blog-pills" id="blogPills">
        {categories.map(cat => (
          <button class={`blog-pill${cat === 'All' ? ' active' : ''}`} data-category={cat}>{cat}</button>
        ))}
      </div>

      <!-- Post Grid -->
      <div class="blog-grid" id="blogGrid">
        {posts.map(post => (
          <a class="blog-card" href={`/blog/${post.id}/`} data-category={post.data.category}>
            <span class="blog-card-category">{post.data.category}</span>
            <h3 class="blog-card-title">{post.data.title}</h3>
            <p class="blog-card-desc">{post.data.description}</p>
            <div class="blog-card-meta">
              <time datetime={post.data.date.toISOString().slice(0, 10)}>{formatDate(post.data.date)}</time>
              <span class="blog-meta-sep">&middot;</span>
              <span>{readTime(post.body ?? '')} min read</span>
            </div>
          </a>
        ))}
      </div>

      <!-- Empty state (shown when no posts match filter) -->
      <div class="blog-empty" id="blogEmpty" style="display:none;">
        <p>No posts in this category yet. Check back soon.</p>
      </div>

    </div>
  </div>

  <!-- Category Filter Script -->
  <script is:inline>
    (function() {
      var pills = document.querySelectorAll('.blog-pill');
      var cards = document.querySelectorAll('.blog-card');
      var empty = document.getElementById('blogEmpty');

      pills.forEach(function(pill) {
        pill.addEventListener('click', function() {
          pills.forEach(function(p) { p.classList.remove('active'); });
          pill.classList.add('active');
          var cat = pill.getAttribute('data-category');
          var visible = 0;
          cards.forEach(function(card) {
            if (cat === 'All' || card.getAttribute('data-category') === cat) {
              card.style.display = '';
              visible++;
            } else {
              card.style.display = 'none';
            }
          });
          empty.style.display = visible === 0 ? '' : 'none';
        });
      });
    })();
  </script>

</BaseLayout>
