---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Readiness Assessment — How to Use Psychedelics"
  description="A ten-question self-assessment covering intention, psychological safety, set and setting, and integration readiness. Completely private — nothing is stored."
  canonicalPath="/readiness"
  hideProgress={true}
>

  <div class="ra-page-wrap">
    <div class="ra-section-inner">

      <div class="breadcrumb" style="padding-top:1.5rem; margin-bottom:0;">
        <a href="/">Home</a>
        <span class="breadcrumb-sep">/</span>
        <span>Readiness Assessment</span>
      </div>

      <div class="ra-section-header">
        <div class="ra-eyebrow">Safety &amp; Readiness</div>
        <h1 class="ra-page-title">Are You <span class="accent-word">Ready?</span></h1>
        <p class="ra-section-sub">A short self-assessment to help you understand where you are &mdash; and what you might need &mdash; before moving forward.</p>
      </div>

      <div class="ra-card" id="ra-root">

        <!-- INTRO VIEW -->
        <div id="ra-view-intro">
          <p class="ra-intro-headline">Before you begin, pause.</p>
          <p class="ra-intro-body">Preparation is not a formality &mdash; it is part of the experience itself. This ten-question assessment covers intention, psychological safety, set and setting, and integration readiness. It takes about five minutes. Your answers are completely private and are not stored anywhere.</p>
          <div class="ra-intro-meta">
            <span class="ra-meta-pill"><span class="ra-meta-dot"></span>10 questions</span>
            <span class="ra-meta-pill"><span class="ra-meta-dot"></span>5 minutes</span>
            <span class="ra-meta-pill"><span class="ra-meta-dot"></span>Completely private</span>
          </div>
          <button class="ra-btn-primary" id="ra-start">Begin Assessment &rarr;</button>
          <p class="ra-intro-disclaimer">This is an educational tool, not a medical or clinical assessment. It does not substitute for professional consultation. If you are managing a significant mental health condition, please speak with a qualified clinician before considering a psychedelic experience.</p>
        </div>

        <!-- QUIZ VIEW -->
        <div id="ra-view-quiz" style="display:none;">
          <div class="ra-progress-wrap">
            <div class="ra-progress-track">
              <div class="ra-progress-fill" id="ra-fill"></div>
            </div>
            <div class="ra-progress-labels">
              <span id="ra-q-counter">Question 1 of 10</span>
              <span id="ra-q-pct">0%</span>
            </div>
          </div>
          <div id="ra-question-block">
            <div class="ra-q-category" id="ra-q-cat"></div>
            <div class="ra-q-text" id="ra-q-text"></div>
            <div class="ra-q-hint" id="ra-q-hint"></div>
            <div class="ra-options" id="ra-opts"></div>
          </div>
          <div class="ra-nav">
            <button class="ra-btn-back" id="ra-back" disabled>&larr; Back</button>
            <button class="ra-btn-next" id="ra-next" disabled>Continue &rarr;</button>
          </div>
        </div>

        <!-- RESULT VIEW -->
        <div id="ra-view-result" style="display:none;"></div>

      </div>
    </div>
  </div>

  <script is:inline>
  (function() {
    var QS = [
      { id:'intention', cat:'Motivation & Intention',
        q:'What is drawing you toward this experience?',
        hint:'Choose the answer that feels most honest right now.',
        opts:[
          { t:'Curiosity and personal growth', v:'growth', flag:null },
          { t:'Healing from specific pain, trauma, or grief', v:'healing', flag:null },
          { t:'Spiritual exploration or deepening', v:'spiritual', flag:null },
          { t:'Relief from or escape from my current life', v:'escape', flag:'hard', hk:'escape' },
          { t:'I\u2019m not yet sure', v:'unsure', flag:'soft' }
        ]
      },
      { id:'mh_history', cat:'Psychological Safety',
        q:'Have you, or a close family member, ever experienced psychosis, schizophrenia, or bipolar\u00a0I\u00a0disorder?',
        hint:'This is a key safety question. There are no wrong answers here.',
        opts:[
          { t:'No, not to my knowledge', v:'no', flag:null },
          { t:'Yes, or I\u2019m unsure', v:'yes', flag:'hard', hk:'mh_history' }
        ]
      },
      { id:'current_state', cat:'Psychological Safety',
        q:'How would you describe your current emotional and mental state?',
        hint:'Be as honest as you can \u2014 this shapes everything that follows.',
        opts:[
          { t:'Stable and relatively grounded', v:'stable', flag:null },
          { t:'Managing some stress, but functional', v:'stressed', flag:null },
          { t:'Going through significant difficulty or upheaval', v:'difficult', flag:'soft' },
          { t:'In acute crisis or overwhelm', v:'crisis', flag:'hard', hk:'crisis' }
        ]
      },
      { id:'medications', cat:'Physical Health',
        q:'Are you currently taking any psychiatric or cardiovascular medications?',
        hint:'SSRIs, SNRIs, MAOIs, antipsychotics, lithium, heart medications, or blood thinners.',
        opts:[
          { t:'No', v:'no', flag:null },
          { t:'Yes', v:'yes', flag:'hard', hk:'medications' },
          { t:'I\u2019m not certain what I\u2019m taking', v:'unsure', flag:'hard', hk:'medications' }
        ]
      },
      { id:'setting', cat:'Set & Setting',
        q:'Do you have access to a safe, comfortable, and private space for the experience?',
        hint:'Where you are shapes what you encounter.',
        opts:[
          { t:'Yes, I have access to a suitable space', v:'yes', flag:null },
          { t:'I\u2019m still working this out', v:'working', flag:'soft' },
          { t:'No, not yet', v:'no', flag:'soft' }
        ]
      },
      { id:'sitter', cat:'Set & Setting',
        q:'Will you have a trusted, sober person present or reachable during the experience?',
        hint:'A sitter is one of the most meaningful harm reduction factors available to you.',
        opts:[
          { t:'Yes \u2014 an experienced guide or facilitator', v:'experienced', flag:null },
          { t:'Yes \u2014 a trusted friend or partner', v:'trusted', flag:null },
          { t:'No \u2014 I would be alone', v:'no', flag:'soft' }
        ]
      },
      { id:'substance', cat:'Set & Setting',
        q:'Do you know exactly what substance you plan to use, and do you trust its source?',
        hint:'Knowing what you\u2019re taking is foundational to safety.',
        opts:[
          { t:'Yes \u2014 tested it or obtained from a fully trusted source', v:'verified', flag:null },
          { t:'Mostly \u2014 I have a reasonable level of trust in the source', v:'trusted', flag:null },
          { t:'Not yet \u2014 I\u2019m still figuring this out', v:'unsure', flag:'soft' }
        ]
      },
      { id:'int_time', cat:'Integration Capacity',
        q:'Do you have 1\u20133 days free after the experience for rest and reflection?',
        hint:'What happens after the experience matters as much as the experience itself.',
        opts:[
          { t:'Yes \u2014 I\u2019ve intentionally protected this time', v:'yes', flag:null },
          { t:'Partially \u2014 I have one day, maybe two', v:'partial', flag:null },
          { t:'No \u2014 I\u2019d need to return to regular life quickly', v:'no', flag:'soft' }
        ]
      },
      { id:'support', cat:'Integration Capacity',
        q:'Do you have at least one person you can speak to openly about this experience?',
        hint:'Integration is rarely a solo process.',
        opts:[
          { t:'Yes \u2014 someone I trust deeply', v:'yes', flag:null },
          { t:'Somewhat \u2014 someone who might understand', v:'somewhat', flag:null },
          { t:'No \u2014 I\u2019d be navigating this alone', v:'no', flag:'soft' }
        ]
      },
      { id:'preparation', cat:'Preparation',
        q:'Have you done any intentional preparation for this experience?',
        hint:'Reading, journaling, meditation, setting intentions, or working with a guide.',
        opts:[
          { t:'Yes \u2014 I\u2019ve been actively preparing', v:'yes', flag:null },
          { t:'Some \u2014 I\u2019ve begun but could go deeper', v:'some', flag:null },
          { t:'Not yet', v:'no', flag:'soft' }
        ]
      }
    ];

    function buildResultHTML(hard, soft) {
      var tier = (hard.length > 0 || soft.length >= 5) ? 'pause'
               : (soft.length >= 2) ? 'prepare' : 'ready';
      var hks = hard.map(function(h){ return h.hk; });
      var badges = { pause:'Pause & Prepare', prepare:'Almost Ready', ready:'Well-Positioned' };
      var headlines = {
        pause: 'Now may not be the right moment.',
        prepare: 'You\u2019re on the right path.',
        ready: 'You appear well-positioned to move forward.'
      };
      var subs = {
        pause: 'This is not a closed door \u2014 it is an invitation to build the foundation that will make this experience genuinely worthwhile. Please read on carefully.',
        prepare: 'A few areas of preparation would meaningfully strengthen your foundation. Addressing these before moving forward will shape the quality of what you encounter.',
        ready: 'Your answers reflect a foundation of intention, care, and preparation. That doesn\u2019t remove all uncertainty \u2014 it never does. But it puts you in a strong position to meet what arises.'
      };
      var items = [];
      if (tier === 'pause') {
        if (hks.indexOf('mh_history') > -1) {
          items.push({ ic:'warn', ico:'\u26A0', t:'Investigate your family mental health history',
            b:'Personal or family histories of psychosis, schizophrenia, or bipolar\u00a0I disorder are significant risk factors. If you\u2019re unsure, speak with family members, review any medical records, or ask your family doctor. Once you have a clearer picture, we recommend consulting a mental health clinician experienced in psychedelic medicine before moving forward.' });
        }
        if (hks.indexOf('crisis') > -1) {
          items.push({ ic:'warn', ico:'\u26A0', t:'Current acute distress or crisis',
            b:'Psychedelics tend to amplify and intensify whatever is present \u2014 including emotional states. Entering an experience during acute crisis can deepen distress rather than resolve it. Please reach out to a mental health professional or trusted support person first.' });
        }
        if (hks.indexOf('medications') > -1) {
          items.push({ ic:'warn', ico:'\u26A0', t:'Current medications',
            b:'Certain medications \u2014 particularly SSRIs, MAOIs, antipsychotics, and lithium \u2014 can interact significantly with serotonergic psychedelics, ranging from blunted effects to serious physiological risk. Please consult a physician experienced in psychedelic medicine before proceeding. Use our <a href="/checker" style="color:var(--accent)">Drug Interaction Checker</a> for specific substance pairs.' });
        }
        if (hks.indexOf('escape') > -1) {
          items.push({ ic:'warn', ico:'\u26A0', t:'Your intention may need more attention',
            b:'Psychedelics amplify what is already present \u2014 including the desire to escape. An escape-oriented intention can intensify rather than dissolve difficulty, leading to an experience that deepens distress rather than offering relief. This doesn\u2019t mean you shouldn\u2019t ever have this experience \u2014 but it means the timing and your relationship to the intention deserve careful reflection first. Consider working with a therapist or trusted guide to explore what you\u2019re hoping to escape from before moving forward.' });
        }
        if (hard.length === 0) {
          items.push({ ic:'info', ico:'\u25CE', t:'Several areas of preparation need attention',
            b:'Your answers suggest a number of areas \u2014 setting, support, integration time, and preparation \u2014 that would benefit from more attention before moving forward.' });
        }
      }
      var softLabels = {
        intention: { ico:'\u25CE', t:'Clarifying your intention',
          b:'Your intention appears oriented toward relief or escape rather than exploration. Psychedelics amplify what is present, and an escape-oriented intention can intensify rather than dissolve difficulty. Spend more time with your \u2018why\u2019 before moving forward.' },
        setting: { ico:'\u25CE', t:'Securing your setting',
          b:'Before you proceed, identify a space that feels genuinely safe, comfortable, and private \u2014 somewhere you can move freely and be fully yourself.' },
        sitter: { ico:'\u25CE', t:'Finding a trusted sitter',
          b:'Having a calm, sober, trusted presence available during your experience is one of the most meaningful harm reduction factors available to you. Even if that person isn\u2019t in the room, knowing they\u2019re reachable can significantly stabilise the experience.' },
        substance: { ico:'\u25CE', t:'Knowing your substance',
          b:'Clarity about what you\u2019re taking \u2014 and confidence in its source \u2014 is foundational. Consider using a reagent testing kit, or take the time to establish a fully trusted source before proceeding.' },
        int_time: { ico:'\u25CE', t:'Protecting integration time',
          b:'If at all possible, protect 1\u20133 days of relative stillness and space afterward \u2014 without major obligations or demands.' },
        support: { ico:'\u25CE', t:'Building integration support',
          b:'Integration is rarely a solo process. Consider identifying one trusted person you can debrief with openly, or joining an integration circle or community.' },
        preparation: { ico:'\u25CE', t:'Deepening your preparation',
          b:'Intentional preparation can make a significant difference. Setting clear intentions, journaling, and learning from others\u2019 experiences are among the most valuable things you can do before the day arrives.' }
      };
      if (tier === 'prepare') {
        soft.forEach(function(s) {
          if (softLabels[s]) items.push({ ic:'info', ico:softLabels[s].ico, t:softLabels[s].t, b:softLabels[s].b });
        });
      }
      if (tier === 'ready') {
        items = [
          { ic:'check', ico:'\u2713', t:'Stay in relationship with your intention',
            b:'Even with strong preparation, returning to your intention throughout \u2014 before, during, and after \u2014 deepens what becomes possible.' },
          { ic:'check', ico:'\u2713', t:'Integration begins now',
            b:'The integration process starts before the experience, not after. The attention you bring to preparation, setting, and relationship will shape what you carry forward.' },
          { ic:'check', ico:'\u2713', t:'Hold the experience lightly',
            b:'Whatever arises \u2014 whether profound, difficult, or quietly ordinary \u2014 is information. Resist the urge to fix its meaning too quickly. Let it continue to speak in the days and weeks that follow.' }
        ];
      }
      var steps = (tier === 'ready')
        ? [ { t:'Explore integration practices', h:'/integration' },
            { t:'Open the Journey Planner', h:'/planner' },
            { t:'Check drug interactions', h:'/checker' } ]
        : [ { t:'Read the preparation guide', h:'/preparation' },
            { t:'Open the Journey Planner', h:'/planner' },
            { t:'Check drug interactions', h:'/checker' } ];
      var itemsHTML = items.map(function(item) {
        return '<div class="ra-result-item">'
          + '<div class="ra-item-header">'
          + '<span class="ra-item-icon ' + item.ic + '">' + item.ico + '</span>'
          + '<span class="ra-item-title">' + item.t + '</span>'
          + '</div><p class="ra-item-body">' + item.b + '</p></div>';
      }).join('');
      var stepsHTML = steps.map(function(s) {
        return '<a class="ra-next-btn" href="' + s.h + '">' + s.t + '</a>';
      }).join('');
      return '<div class="ra-result-badge tier-' + tier + '">' + badges[tier] + '</div>'
        + '<h3 class="ra-result-headline">' + headlines[tier] + '</h3>'
        + '<p class="ra-result-sub">' + subs[tier] + '</p>'
        + '<div class="ra-result-items">' + itemsHTML + '</div>'
        + '<p class="ra-next-label">Where to go from here</p>'
        + '<div class="ra-next-steps">' + stepsHTML + '</div>'
        + '<button class="ra-restart" id="ra-restart">Start over</button>'
        + '<p class="ra-result-disclaimer">This assessment is for educational purposes only. It does not constitute medical or clinical advice and is not a substitute for professional consultation. If you are managing a mental health condition, taking psychiatric medications, or have concerns about your readiness, please speak with a qualified clinician before proceeding.</p>';
    }

    var current = 0;
    var answers = {};
    var viewIntro = document.getElementById('ra-view-intro');
    var viewQuiz = document.getElementById('ra-view-quiz');
    var viewResult = document.getElementById('ra-view-result');
    var fillEl = document.getElementById('ra-fill');
    var counterEl = document.getElementById('ra-q-counter');
    var pctEl = document.getElementById('ra-q-pct');
    var catEl = document.getElementById('ra-q-cat');
    var qEl = document.getElementById('ra-q-text');
    var hintEl = document.getElementById('ra-q-hint');
    var optsEl = document.getElementById('ra-opts');
    var qBlock = document.getElementById('ra-question-block');
    var backBtn = document.getElementById('ra-back');
    var nextBtn = document.getElementById('ra-next');

    function renderQ(idx, instant) {
      var q = QS[idx];
      var pct = Math.round((idx / QS.length) * 100);
      fillEl.style.width = pct + '%';
      counterEl.textContent = 'Question ' + (idx + 1) + ' of ' + QS.length;
      pctEl.textContent = pct + '%';
      function populate() {
        catEl.textContent = q.cat;
        qEl.textContent = q.q;
        hintEl.textContent = q.hint;
        var html = '';
        q.opts.forEach(function(opt) {
          var sel = answers[q.id] === opt.v ? ' is-selected' : '';
          html += '<button class="ra-option' + sel + '" data-val="' + opt.v + '">'
            + '<span class="ra-radio"><span class="ra-radio-dot"></span></span>'
            + '<span class="ra-option-label">' + opt.t + '</span></button>';
        });
        optsEl.innerHTML = html;
        optsEl.querySelectorAll('.ra-option').forEach(function(btn) {
          btn.addEventListener('click', function() {
            answers[q.id] = btn.getAttribute('data-val');
            optsEl.querySelectorAll('.ra-option').forEach(function(b){ b.classList.remove('is-selected'); });
            btn.classList.add('is-selected');
            nextBtn.disabled = false;
          });
        });
        nextBtn.disabled = !answers[q.id];
        backBtn.disabled = (idx === 0);
        if (!instant) {
          qBlock.classList.remove('ra-q-fade-out');
          qBlock.classList.add('ra-q-fade-in');
        }
      }
      if (instant) { populate(); }
      else {
        qBlock.classList.remove('ra-q-fade-in');
        qBlock.classList.add('ra-q-fade-out');
        setTimeout(populate, 210);
      }
    }

    function showResult() {
      var hard = [], soft = [];
      QS.forEach(function(q) {
        var val = answers[q.id];
        if (!val) return;
        var opt = null;
        for (var i = 0; i < q.opts.length; i++) { if (q.opts[i].v === val) { opt = q.opts[i]; break; } }
        if (!opt) return;
        if (opt.flag === 'hard') hard.push({ qid:q.id, hk:opt.hk });
        else if (opt.flag === 'soft') soft.push(q.id);
      });
      fillEl.style.width = '100%';
      pctEl.textContent = '100%';
      viewQuiz.style.display = 'none';
      viewResult.innerHTML = buildResultHTML(hard, soft);
      viewResult.style.display = 'block';
      document.getElementById('ra-restart').addEventListener('click', function() {
        answers = {}; current = 0;
        viewResult.style.display = 'none';
        viewResult.innerHTML = '';
        fillEl.style.width = '0%';
        viewIntro.style.display = 'block';
      });
    }

    document.getElementById('ra-start').addEventListener('click', function() {
      viewIntro.style.display = 'none';
      viewQuiz.style.display = 'block';
      renderQ(0, true);
    });
    nextBtn.addEventListener('click', function() {
      if (!answers[QS[current].id]) return;
      current++;
      if (current >= QS.length) { showResult(); return; }
      renderQ(current, false);
    });
    backBtn.addEventListener('click', function() {
      if (current === 0) return;
      current--;
      renderQ(current, false);
    });
  })();
  </script>

</BaseLayout>
