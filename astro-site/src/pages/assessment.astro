            function buildTable(tableId){
              var table = document.getElementById(tableId);
              if(!table) return;
              var hRow = document.createElement('tr');
              var corner = document.createElement('th');
              corner.className = 'combo-corner';
              hRow.appendChild(corner);
              substances.forEach(function(sub){
                var th = document.createElement('th');
                th.className = 'combo-col-head';
                th.innerHTML = '<span>'+sub.label+'</span>';
                hRow.appendChild(th);
              });
              table.appendChild(hRow);
              substances.forEach(function(rS){
                var tr = document.createElement('tr');
                var rh = document.createElement('td');
                rh.className = 'combo-row-head';
                rh.textContent = rS.label;
                tr.appendChild(rh);
                substances.forEach(function(cS){
                  var td = document.createElement('td');
                  var data = g(rS.id, cS.id);
                  td.className = 'cc '+data.rating;
                  td.textContent = ICONS[data.rating]||'';
                  if(data.rating !== SE){
                    td.addEventListener('mousemove', function(e){
                      var tip = document.getElementById('comboTip');
                      var ctR = document.getElementById('ct-rating');
                      var ctP = document.getElementById('ct-pair');
                      var ctN = document.getElementById('ct-note');
                      if(!tip) return;
                      tip.classList.add('vis');
                      ctR.className = 'combo-tip-rating '+data.rating;
                      ctR.textContent = LABELS[data.rating]||'';
                      ctP.textContent = rS.label+' + '+cS.label;
                      ctN.textContent = data.note;
                      var x=e.clientX+16, y=e.clientY+16;
                      if(x+280>window.innerWidth) x=e.clientX-285;
                      if(y+140>window.innerHeight) y=e.clientY-140;
                      tip.style.left=x+'px'; tip.style.top=y+'px';
                    });
                    td.addEventListener('mouseleave',function(){ var tip=document.getElementById('comboTip'); if(tip) tip.classList.remove('vis'); });
                  }
                  tr.appendChild(td);
                });
                table.appendChild(tr);
              });
            }

            function buildMobileLookup(selAId, selBId, resultId, ratingId, pairId, noteId){
              var selA = document.getElementById(selAId);
              var selB = document.getElementById(selBId);
              if(!selA || !selB) return;
              substances.forEach(function(sub){
                selA.appendChild(Object.assign(document.createElement('option'),{value:sub.id,textContent:sub.label}));
                selB.appendChild(Object.assign(document.createElement('option'),{value:sub.id,textContent:sub.label}));
              });
              function updateResult(){
                var a=selA.value, b=selB.value;
                var res=document.getElementById(resultId);
                if(!a||!b){ if(res) res.classList.remove('vis'); return; }
                var data=g(a,b);
                res.className='combo-result vis '+data.rating;
                document.getElementById(ratingId).textContent = LABELS[data.rating]||'';
                var rL = substances.find(function(x){return x.id===a}).label;
                var cL = substances.find(function(x){return x.id===b}).label;
                document.getElementById(pairId).textContent = rL+' + '+cL;
                document.getElementById(noteId).textContent = data.note;
              }
              selA.addEventListener('change',updateResult);
              selB.addEventListener('change',updateResult);
            }

            return { buildTable:buildTable, buildMobileLookup:buildMobileLookup };
          })();

          window._combo.buildTable('comboTable');
          window._combo.buildMobileLookup('sub-a','sub-b','combo-result','cr-rating','cr-pair','cr-note');
