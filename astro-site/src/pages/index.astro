---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="How to Use Psychedelics — Education & Harm Reduction"
  description="Evidence-informed education on psychedelics — foundations, substances, microdosing, journeying, and facilitation. Grounded in harm reduction and the Psygaia Framework."
  hideProgress={true}
>

  <!-- ── HERO ─────────────────────────────────────────────────── -->
  <div class="hero">
    <div class="hero-badge">Education &amp; Harm Reduction</div>
    <h1>Learn to engage with <br class="desktop-br">psychedelics <span class="accent-word"><span class="word active">responsibly</span><span class="word">intentionally</span><span class="word">mindfully</span><span class="word">safely</span><span class="word">respectfully</span><span class="word">wisely</span></span></h1>
    <p class="hero-sub">Evidence-informed education on preparation, navigation, integration, and more — grounded in harm reduction and the Psygaia Framework.</p>
    <div class="hero-cta">
      <a href="/planner" class="btn btn-primary">Plan Your Journey</a>
      <a href="/journeying" class="btn btn-outline">Journeying Guide</a>
    </div>
    <div class="hero-trust">
      <div class="hero-trust-item">
        <svg class="hero-trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
        <div class="hero-trust-text">
          <span class="hero-trust-label">Ad-Free</span>
          <span class="hero-trust-desc">No ads, no sponsors</span>
        </div>
      </div>
      <div class="hero-trust-item">
        <svg class="hero-trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19.5 8.5c.7-.7 1.5-1.6 1.5-2.7A2.73 2.73 0 0 0 16 4a2.78 2.78 0 0 0-5 1.8c0 1.1.8 2 1.5 2.7L16 12z"/><path d="M11 14h2a2 2 0 1 0 0-4h-3c-.6 0-1.1.2-1.4.6L3 16"/><path d="M7 20l1.6-1.4c.3-.4.8-.6 1.4-.6h4c1.1 0 2.1-.4 2.8-1.2l4.6-4.4a2 2 0 0 0-2.75-2.91l-3.07 2.57"/><path d="M2 15l6 6"/></svg>
        <div class="hero-trust-text">
          <span class="hero-trust-label">Independent Nonprofit</span>
          <span class="hero-trust-desc">Built by Psygaia, for public benefit</span>
        </div>
      </div>
      <div class="hero-trust-item">
        <svg class="hero-trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"/><path d="M8.5 2h7"/></svg>
        <div class="hero-trust-text">
          <span class="hero-trust-label">Evidence-Informed</span>
          <span class="hero-trust-desc">Grounded in science and harm reduction</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ── START HERE — Colourful direction cards ──────────────── -->
  <div class="start-here">
    <div class="section">
      <div class="section-header reveal">
        <div class="section-label">Where to begin</div>
        <div class="section-title">Find your<br class="mobile-br"> <span class="grad-text">starting point</span></div>
      </div>
      <div class="start-grid reveal">
        <a href="/foundations" class="start-card start-card-1">
          <h3>New to Psychedelics</h3>
          <p>The science, cultural history, legal landscape, and ecological context you need before anything else.</p>
          <div class="card-arrow">Explore &rarr;</div>
        </a>
        <a href="/preparation" class="start-card start-card-2">
          <h3>Planning an Experience</h3>
          <p>Assess your readiness, set clear intentions, and build a personalised preparation and integration plan.</p>
          <div class="card-arrow">Explore &rarr;</div>
        </a>
        <a href="/substances" class="start-card start-card-3">
          <h3>Researching a Substance</h3>
          <p>In-depth profiles covering pharmacology, dosage, risks, drug interactions, and legal status for each substance.</p>
          <div class="card-arrow">Explore &rarr;</div>
        </a>
        <a href="/integration" class="start-card start-card-4">
          <h3>After an Experience</h3>
          <p>How to make meaning from the experience and translate insight into lasting, grounded change in your life.</p>
          <div class="card-arrow">Explore &rarr;</div>
        </a>
      </div>
    </div>
  </div>

  <!-- ── ALL TOPICS ──────────────────────────────────────────── -->
  <div class="section">
    <div class="section-header reveal">
      <div class="section-label">All Topics</div>
      <div class="section-title">Everything you<br class="mobile-br"> need to navigate<br><span class="grad-text">psychedelics safely</span></div>
    </div>
    <div class="topics-grid reveal">
      <a href="/foundations" class="topic-card">
        <div class="topic-icon topic-icon-1">
          <!-- Layers / building blocks -->
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
        </div>
        <div class="topic-card-num">01 Foundations</div>
        <div class="topic-card-title">Basic Literacy</div>
        <div class="topic-card-arrow">Explore &rarr;</div>
      </a>
      <a href="/substances" class="topic-card">
        <div class="topic-icon topic-icon-2">
          <!-- Flask / chemistry -->
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"/><path d="M8.5 2h7"/></svg>
        </div>
        <div class="topic-card-num">02 Substances</div>
        <div class="topic-card-title">Substance Guides</div>
        <div class="topic-card-arrow">Explore &rarr;</div>
      </a>
      <a href="/microdosing" class="topic-card">
        <div class="topic-icon topic-icon-3">
          <!-- Droplet — micro dose -->
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>
        </div>
        <div class="topic-card-num">03 Microdosing</div>
        <div class="topic-card-title">Low-Dose Practice</div>
        <div class="topic-card-arrow">Explore &rarr;</div>
      </a>
      <a href="/assessment" class="topic-card">
        <div class="topic-icon topic-icon-4">
          <!-- Shield check — readiness -->
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
        </div>
        <div class="topic-card-num">04 Assessment</div>
        <div class="topic-card-title">Are You Ready?</div>
        <div class="topic-card-arrow">Explore &rarr;</div>
      </a>
      <a href="/preparation" class="topic-card">
        <div class="topic-icon topic-icon-5">
          <!-- Clipboard / checklist — set & setting -->
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/><line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="13" y2="16"/></svg>
        </div>
        <div class="topic-card-num">05 Preparation</div>
        <div class="topic-card-title">Set &amp; Setting</div>
        <div class="topic-card-arrow">Explore &rarr;</div>
      </a>
      <a href="/navigation" class="topic-card">
        <div class="topic-icon topic-icon-6">
          <!-- Compass — navigating the experience -->
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>
        </div>
        <div class="topic-card-num">06 Navigation</div>
        <div class="topic-card-title">During the Experience</div>
        <div class="topic-card-arrow">Explore &rarr;</div>
      </a>
      <a href="/integration" class="topic-card">
        <div class="topic-icon topic-icon-7">
          <!-- Puzzle piece — integration / fitting together -->
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19.439 7.85c-.049.322.059.648.289.878l1.568 1.568c.47.47.706 1.087.706 1.704s-.235 1.233-.706 1.704l-1.611 1.611a.98.98 0 0 1-.837.276c-.47-.07-.802-.48-.968-.925a2.501 2.501 0 1 0-3.214 3.214c.446.166.855.497.925.968a.979.979 0 0 1-.276.837l-1.61 1.611a2.404 2.404 0 0 1-1.705.707 2.402 2.402 0 0 1-1.704-.707l-1.568-1.568a1.026 1.026 0 0 0-.877-.29c-.493.074-.84.504-1.02.968a2.5 2.5 0 1 1-3.237-3.237c.464-.18.894-.527.967-1.02a1.026 1.026 0 0 0-.289-.877l-1.568-1.568A2.404 2.404 0 0 1 1.998 12c0-.617.236-1.234.706-1.704L4.315 8.685a.98.98 0 0 1 .837-.276c.47.07.802.48.968.925a2.501 2.501 0 1 0 3.214-3.214c-.446-.166-.855-.497-.925-.968a.979.979 0 0 1 .276-.837l1.611-1.611a2.404 2.404 0 0 1 1.704-.706c.617 0 1.234.236 1.704.706l1.568 1.568c.23.23.556.338.877.29.493-.074.84-.504 1.02-.968a2.5 2.5 0 1 1 3.237 3.237c-.464.18-.894.527-.967 1.02z"/></svg>
        </div>
        <div class="topic-card-num">07 Integration</div>
        <div class="topic-card-title">After the Journey</div>
        <div class="topic-card-arrow">Explore &rarr;</div>
      </a>
      <a href="/facilitation" class="topic-card">
        <div class="topic-icon topic-icon-8">
          <!-- Hand / heart — holding space -->
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 14h2a2 2 0 1 0 0-4h-3c-.6 0-1.1.2-1.4.6L3 16"/><path d="M7 20l1.6-1.4c.3-.4.8-.6 1.4-.6h4c1.1 0 2.1-.4 2.8-1.2l4.6-4.4a2 2 0 0 0-2.75-2.91l-3.07 2.57"/><path d="M2 15l6 6"/><path d="M19.5 8.5c.7-.7 1.5-1.6 1.5-2.7A2.73 2.73 0 0 0 16 4a2.78 2.78 0 0 0-5 1.8c0 1.1.8 2 1.5 2.7L16 12z"/></svg>
        </div>
        <div class="topic-card-num">08 Facilitation</div>
        <div class="topic-card-title">Holding Space</div>
        <div class="topic-card-arrow">Explore &rarr;</div>
      </a>
    </div>
  </div>

  <!-- ── TOOLS ───────────────────────────────────────────────── -->
  <div class="tools-section">
    <div class="section">
      <div class="section-header reveal">
        <div class="section-label">Interactive Tools</div>
        <div class="section-title">Tools built for<br class="mobile-br"> <span class="grad-text">intentional practice</span></div>
      </div>
      <div class="tools-grid reveal">
        <a href="/readiness" class="tool-card">
          <div class="tool-badge tool-badge-1">Self-Assessment</div>
          <h3>Readiness Assessment</h3>
          <p>Evaluate your intention, psychological safety, and integration readiness.</p>
          <div class="tool-card-cta">Begin Assessment &rarr;</div>
        </a>
        <a href="/planner" class="tool-card">
          <div class="tool-badge tool-badge-2">Personalised</div>
          <h3>Journey Planner</h3>
          <p>Build a preparation timeline and integration plan tailored to you.</p>
          <div class="tool-card-cta">Open Planner &rarr;</div>
        </a>
        <a href="/checker" class="tool-card">
          <div class="tool-badge tool-badge-3">Safety Reference</div>
          <h3>Interaction Checker</h3>
          <p>Check common psychedelic drug interactions and harm reduction guidance.</p>
          <div class="tool-card-cta">Check Interactions &rarr;</div>
        </a>
      </div>
    </div>
  </div>

  <!-- ── COURSE PROMO ─────────────────────────────────────────── -->
  <div class="course-promo">
    <div class="course-promo-inner reveal">
      <div class="course-promo-content">
        <div class="section-label">Dive into Psygaia</div>
        <h2 class="course-promo-title">Microdose with <span class="grad-text">Mindfulness</span></h2>
        <p class="course-promo-body">
          Not a protocol. Not a productivity hack. A structured 3-week course for those who want to engage with microdosing as a genuine practice — fifteen evidence-informed lessons on preparation, reflection, and integration.
        </p>
        <div class="course-promo-pills">
          <div class="course-promo-pills-row">
            <span class="course-pill">3 weeks · 15 lessons</span>
            <span class="course-pill">Evidence-informed</span>
          </div>
          <div class="course-promo-pills-row">
            <span class="course-pill">Community included</span>
            <span class="course-pill">14-day guarantee</span>
          </div>
        </div>
        <a href="/microdosing-course" class="btn btn-primary">Explore the Course &rarr;</a>
        <p class="course-promo-price-note">$99 USD &middot; 14-day guarantee</p>
      </div>
      <div class="course-promo-aside">
        <div class="course-promo-card">
          <div class="course-promo-card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          </div>
          <div>
            <div class="course-promo-card-title">Microdosing with Mindfulness</div>
            <p class="course-promo-card-body">Self-paced lessons on preparation, reflection, and integration. Work through the material in your own time, at your own rhythm.</p>
          </div>
        </div>
        <div class="course-promo-card">
          <div class="course-promo-card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <div>
            <div class="course-promo-card-title">Psygaia's Circle — Included</div>
            <p class="course-promo-card-body">Lifetime access to a moderated community for intentional practice. Monthly integration and breathwork circles with our guides.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── PSYGAIA STRIP ───────────────────────────────────────── -->
  <div class="feature-strip-section">
    <div class="feature-strip reveal">
      <div class="section-label">The Psygaia Framework</div>
      <div class="section-title">An <span class="grad-text">ecological</span> theory of psychedelics</div>
      <p>Why do psychedelic experiences so consistently produce a felt sense of connection with a living world? The Psygaia Framework offers a rigorous, systems-based account.</p>
      <a class="btn btn-outline" href="https://psygaia.org/psygaia-hypothesis" target="_blank" rel="noopener">Read the Research &rarr;</a>
    </div>
  </div>

  <!-- ── SUPPORT BANNER ──────────────────────────────────────── -->
  <div class="support-banner">
    <div class="support-inner">
      <div class="support-text">
        <h2>This work exists because people like you care.</h2>
        <p>Psygaia is an independent nonprofit. No ads, no corporate sponsors. Your support keeps this education free and accessible.</p>
      </div>
      <a class="btn btn-primary" href="https://buy.stripe.com/bIYcMX3W893Z4o04gg" target="_blank" rel="noopener">Support This Work &rarr;</a>
    </div>
  </div>

  <!-- ── Rotating hero words script ──────────────────────────── -->
  <script is:inline>
    (function() {
      const words = document.querySelectorAll('.accent-word .word');
      let current = 0;
      setInterval(() => {
        words[current].classList.add('exiting');
        words[current].classList.remove('active');
        setTimeout(() => { words[current === 0 ? words.length - 1 : current - 1].classList.remove('exiting'); }, 500);
        current = (current + 1) % words.length;
        words[current].classList.add('active');
      }, 3000);
    })();
  </script>

</BaseLayout>
